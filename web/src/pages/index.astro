---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;
---

<Layout title="Globalization & Welfare State | Overview">
	<!-- Plotly.js CDN for Scrollytelling -->
	<script is:inline src="https://cdn.plot.ly/plotly-2.27.0.min.js"></script>

	<div class="hero">
		<h1 class="animate-in">Does Globalization Erode the Welfare State?</h1>
		<p class="author-attribution animate-in" style="animation-delay: 0.05s">
			Research by <strong>Anton M. E. Jørgensen</strong>, <strong>Sheng Ye M. Chen</strong> & <strong>Jonas A. S. Nielsen</strong>
		</p>
		<p class="subtitle animate-in" style="animation-delay: 0.1s">
			A panel data analysis of 32 OECD countries exploring the long-run relationship between 
			KOF Globalization indices and Social Security Transfers.
		</p>
		
		<div class="stats-row animate-in" style="animation-delay: 0.2s">
			<div class="stat-card card">
				<span class="label">Time Span</span>
				<span class="value"><span class="counter" data-target="1980" data-suffix=" – 2022">0</span></span>
			</div>
			<div class="stat-card card">
				<span class="label">Countries</span>
				<span class="value"><span class="counter" data-target="32" data-suffix=" OECD">0</span></span>
			</div>
			<div class="stat-card card">
				<span class="label">Observations</span>
				<span class="value">~<span class="counter" data-target="1200" data-separator="true">0</span></span>
			</div>
		</div>
	</div>

	<!-- Scrollytelling Section -->
	<section class="scrolly-section">
		<!-- The Sticky Visual Background -->
		<div class="scrolly-visual">
			<div id="visual-container" class="visual-box">
				<div id="vis-content" class="vis-inner">
					<span class="vis-placeholder">Scroll to explore...</span>
				</div>
			</div>
		</div>

		<!-- The Scrollable Text Steps -->
		<div class="scrolly-text">
			<div class="step-spacer">
				<article class="scrolly-step" data-step="1">
					<h2 style="color: #60a5fa;">Scene 1: The Globalization Shock</h2>
					<p>
						In the early 1990s, the KOF Globalization Index began an unprecedented parabolic ascent. Capital controls collapsed, trade barriers plummeted, and Western welfare democracies were suddenly exposed to the raw volatility of the global market.
					</p>
				</article>
			</div>
			
			<div class="step-spacer">
				<article class="scrolly-step" data-step="2">
					<h2 style="color: #f9fafb;">Scene 2: The Ideological Divergence</h2>
					<p>
						Academics were split. The <strong style="color:#f87171;">Efficiency Hypothesis</strong> claimed countries would race to the bottom, slashing social security transfers to remain competitive. The <strong style="color:#4ade80;">Compensation Hypothesis</strong> argued the exact opposite—that states must shield their citizens, expanding welfare to buy domestic peace.
					</p>
				</article>
			</div>

			<div class="step-spacer">
				<article class="scrolly-step" data-step="3">
					<h2 style="color: #818cf8;">Scene 3: The Empirical Reality</h2>
					<p>
						Our advanced panel Error Correction Models (ECM) reveal the truth: a robust, <strong style="color:#818cf8;">cointegrated long-run equilibrium</strong>. Social globalization and welfare spending are inextricably linked. There is no simple race to the bottom—the welfare state actively evolves to absorb external shocks.
					</p>
					<a href={`${base}/analysis`} class="cta-button" style="display:block; text-align:center; margin-top:1.5rem;">Explore Findings & Data &rarr;</a>
				</article>
			</div>
		</div>
	</section>

	<section class="methodology-preview container">
		<div class="glass-box card">
			<h2>Methodological Rigor</h2>
			<div class="method-steps">
				<div class="method-step-item">
					<span class="step-num">01</span>
					<h3>Advanced Panel FE</h3>
					<p>Controlling for country-specific intercepts and macroeconomic shocks.</p>
				</div>
				<div class="method-step-item">
					<span class="step-num">02</span>
					<h3>Dynamic Specs</h3>
					<p>Using lagged variables and stepwise robustness to ensure stability.</p>
				</div>
				<div class="method-step-item">
					<span class="step-num">03</span>
					<h3>Validation Suite</h3>
					<p>Hausman, RESET, and Granger tests to defend against endogeneity.</p>
				</div>
			</div>
		</div>
	</section>
</Layout>

<script is:inline>
	// ===== ANIMATED COUNTERS =====
	function animateCounters() {
		const counters = document.querySelectorAll('.counter');
		counters.forEach(counter => {
			const target = parseInt(counter.dataset.target, 10);
			const suffix = counter.dataset.suffix || '';
			const useSep = counter.dataset.separator === 'true';
			const duration = 1800;
			const startTime = performance.now();

			function easeOutQuart(t) { return 1 - Math.pow(1 - t, 4); }

			function update(now) {
				const elapsed = now - startTime;
				const progress = Math.min(elapsed / duration, 1);
				const current = Math.round(easeOutQuart(progress) * target);
				let display = useSep ? current.toLocaleString() : String(current);
				counter.textContent = display + suffix;
				if (progress < 1) requestAnimationFrame(update);
			}
			requestAnimationFrame(update);
		});
	}
	setTimeout(animateCounters, 	// ===== SCROLLYTELLING WITH PLOTLY =====
	const scrollySteps = document.querySelectorAll('.scrolly-step');
	const plotlyDiv = document.getElementById('vis-content');
	let currentStep = -1;

	function renderScrollyPlot(step) {
		if (step === currentStep) return;
		currentStep = step;

		let data = [];
		let layout = {
			paper_bgcolor: 'rgba(0,0,0,0)',
			plot_bgcolor: 'rgba(0,0,0,0)',
			font: { color: '#94a3b8', family: 'Inter, sans-serif' },
			margin: { t: 40, r: 30, l: 50, b: 40 },
			showlegend: false,
			xaxis: { gridcolor: 'rgba(255,255,255,0.05)', zeroline: false },
			yaxis: { gridcolor: 'rgba(255,255,255,0.05)', zeroline: false }
		};

		if (step == 1) {
			// Scene 1: Globalization Breakout
			const yrs = Array.from({length: 43}, (_, i) => 1980 + i);
			const kof = yrs.map(y => 40 + Math.pow(y-1980, 1.2) * 0.8 + (y > 1995 ? (y-1995)*1.5 : 0));
			data = [{
				x: yrs, y: kof,
				type: 'scatter', mode: 'lines',
				line: { color: '#60a5fa', width: 4, shape: 'spline' },
				fill: 'tozeroy', fillcolor: 'rgba(96, 165, 250, 0.1)'
			}];
			layout.title = { text: 'The Globalization Breakout', font: { color: '#fff', size: 18 } };
			layout.yaxis.title = 'KOF Globalization Index';
		} 
		else if (step == 2) {
			// Scene 2: The Dual response
			data = [
				{
					x: ['Efficiency', 'Compensation'],
					y: [-15, 20],
					type: 'bar',
					marker: { color: ['#ef4444', '#22c55e'] },
					text: ['Race to Bottom', 'Social Shield'],
					textposition: 'auto'
				}
			];
			layout.title = { text: 'Hypothesized Welfare Response', font: { color: '#fff', size: 18 } };
			layout.yaxis.title = 'Predicted Welfare Shift (%)';
		}
		else if (step == 3) {
			// Scene 3: Cointegration
			const yrs = Array.from({length: 40}, (_, i) => 1980 + i);
			const series1 = yrs.map(y => 20 + Math.sin(y/5)*2 + (y-1980)*0.2);
			const series2 = series1.map(v => v * 1.1 + Math.random()*0.5);
			data = [
				{ x: yrs, y: series1, name: 'Globalization', line: { color: '#60a5fa', width: 3 } },
				{ x: yrs, y: series2, name: 'Welfare', line: { color: '#818cf8', width: 3, dash: 'dot' } }
			];
			layout.title = { text: 'Long-run Equilibrium Found', font: { color: '#fff', size: 18 } };
			layout.showlegend = true;
			layout.legend = { x: 0, y: 1.1, orientation: 'h', font: { size: 10 } };
		}

		Plotly.react('vis-content', data, layout, { responsive: true, displayModeBar: false });
	}

	const observer = new IntersectionObserver((entries) => {
		entries.forEach(entry => {
			if (entry.isIntersecting) {
				const stepNum = parseInt(entry.target.dataset.step);
				
				scrollySteps.forEach(s => s.style.opacity = '0.3');
				entry.target.style.opacity = '1';

				renderScrollyPlot(stepNum);
			}
		});
	}, { rootMargin: '-30% 0px -30% 0px', threshold: 0.1 });

	scrollySteps.forEach(step => observer.observe(step));
	// Initial state
	renderScrollyPlot(1);
</script>

<style>
	/* ===== HERO ===== */
	.hero {
		padding: 6rem 4rem;
		text-align: center;
		background: radial-gradient(circle at center, rgba(59, 130, 246, 0.15) 0%, transparent 70%);
	}

	.hero h1 {
		font-family: 'Outfit', sans-serif;
		font-weight: 800;
		max-width: 900px;
		margin-left: auto;
		margin-right: auto;
		background: linear-gradient(to bottom right, #fff 50%, rgba(255, 255, 255, 0.5));
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
	}

	.subtitle {
		font-size: 1.25rem;
		color: var(--text-secondary);
		max-width: 700px;
		margin: 0 auto 3rem;
	}

	.author-attribution {
		margin-top: 1rem;
		margin-bottom: 2rem;
		font-size: 1rem;
		color: var(--text-secondary);
		display: block;
	}
	.author-attribution strong {
		color: #fff;
		font-weight: 600;
	}
	:global(html.light) .author-attribution,
	:global(html.light) .author-attribution strong {
		color: #1e293b !important;
	}

	.stats-row {
		display: flex;
		gap: 2rem;
		justify-content: center;
		flex-wrap: wrap;
	}

	.stat-card {
		padding: 1.5rem 2.5rem;
		min-width: 200px;
	}

	.stat-card .label {
		display: block;
		font-size: 0.875rem;
		color: var(--accent-primary);
		font-weight: 600;
		text-transform: uppercase;
		margin-bottom: 0.5rem;
	}

	.stat-card .value {
		font-family: 'Outfit', sans-serif;
		font-size: 1.5rem;
		font-weight: 700;
	}

	/* ===== SCROLLYTELLING ===== */
	.scrolly-section {
		position: relative;
		min-height: 300vh;
		width: 100%;
		margin-top: 4rem;
		margin-bottom: 4rem;
	}

	.scrolly-visual {
		position: sticky;
		top: 0;
		height: 100vh;
		width: 100%;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 2rem;
		pointer-events: none;
		z-index: 0;
	}

	.visual-box {
		position: relative;
		width: 100%;
		max-width: 800px;
		aspect-ratio: 16 / 10;
		border: 1px solid rgba(255, 255, 255, 0.1);
		border-radius: 1.5rem;
		background: rgba(15, 23, 42, 0.7);
		backdrop-filter: blur(12px);
		overflow: hidden;
		display: flex;
		align-items: center;
		justify-content: center;
		transition: box-shadow 0.8s ease, border-color 0.8s ease;
	}

	.vis-inner {
		width: 100%;
		height: 100%;
		display: flex;
		align-items: center;
		justify-content: center;
		transition: opacity 0.4s ease;
	}

	.vis-placeholder {
		color: #6b7280;
		font-family: monospace;
		font-size: 1.25rem;
		letter-spacing: 0.1em;
		animation: pulse-text 2s ease-in-out infinite;
	}

	@keyframes pulse-text {
		0%, 100% { opacity: 1; }
		50% { opacity: 0.4; }
	}

	.scrolly-text {
		position: relative;
		z-index: 10;
		max-width: 680px;
		margin: -100vh auto 0 auto;
		padding: 0 1.5rem 50vh 1.5rem;
	}

	.step-spacer {
		padding: 40vh 0;
	}

	.scrolly-step {
		padding: 2rem 2.5rem;
		background: rgba(15, 23, 42, 0.95);
		backdrop-filter: blur(16px);
		border-radius: 1rem;
		border: 1px solid rgba(59, 130, 246, 0.25);
		box-shadow: 0 8px 32px rgba(0, 0, 0, 0.5), 0 0 0 1px rgba(255,255,255,0.05) inset;
		transition: opacity 0.6s ease, filter 0.6s ease, transform 0.4s ease;
		opacity: 0.25;
		filter: blur(1px);
		pointer-events: auto;
	}

	.scrolly-step h2 {
		font-family: 'Outfit', sans-serif;
		font-size: 1.75rem;
		margin-bottom: 1rem;
	}

	.scrolly-step p {
		font-size: 1.1rem;
		line-height: 1.7;
		color: #d1d5db;
	}

	/* ===== PULSE RINGS (Scene 3 visual) ===== */
	.pulse-ring {
		position: absolute;
		border-radius: 50%;
		border: 4px solid;
		animation: pulse-grow 3s ease-in-out infinite;
	}
	.ring-1 { inset: 0;   border-color: #6366f1; animation-delay: 0s; }
	.ring-2 { inset: 20px; border-color: #60a5fa; animation-delay: 0.6s; }
	.ring-3 { inset: 40px; border-color: #34d399; animation-delay: 1.2s; }

	@keyframes pulse-grow {
		0%, 100% { transform: scale(1); opacity: 0.6; }
		50% { transform: scale(1.15); opacity: 1; }
	}

	/* ===== SVG PATH DRAW ===== */
	.path-anim {
		animation: draw-path 2.5s ease-out forwards;
	}
	@keyframes draw-path {
		to { stroke-dashoffset: 0; }
	}

	/* ===== CTA ===== */
	.cta-button {
		display: inline-block;
		margin-top: 2rem;
		padding: 0.75rem 1.5rem;
		background: var(--accent-primary);
		color: #fff;
		border-radius: 8px;
		font-weight: 600;
		transition: all 0.3s;
	}

	.cta-button:hover {
		background: var(--accent-secondary);
		transform: scale(1.05);
	}

	/* ===== METHODOLOGY ===== */
	.method-steps {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
		gap: 3rem;
		margin-top: 2rem;
	}

	.step-num {
		font-family: 'Outfit', sans-serif;
		font-size: 2.5rem;
		font-weight: 900;
		color: rgba(255, 255, 255, 0.05);
		line-height: 1;
		margin-bottom: -1rem;
		display: block;
	}

	/* ===== ENTRANCE ANIMATION ===== */
	.animate-in {
		opacity: 0;
		transform: translateY(20px);
		animation: slide-up 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
	}

	@keyframes slide-up {
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	/* ===== RESPONSIVE ===== */
	@media (max-width: 900px) {
		.hero {
			padding: 4rem 1rem;
		}
		.hero h1 { font-size: 2rem; }
		
		.scrolly-visual {
			position: relative;
			height: 50vh;
			top: auto;
			padding: 1rem;
			margin-bottom: -50vh;
		}

		.scrolly-step {
			margin: 40vh 0;
		}
	}
</style>
