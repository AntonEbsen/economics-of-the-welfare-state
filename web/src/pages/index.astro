---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;
---

<Layout title="Globalization & Welfare State | Overview">
	<div class="hero">
		<h1 class="animate-in">Does Globalization Erode the Welfare State?</h1>
		<p class="subtitle animate-in" style="animation-delay: 0.1s">
			A panel data analysis of 32 OECD countries exploring the long-run relationship between 
			KOF Globalization indices and Social Security Transfers.
		</p>
		
		<div class="stats-row animate-in" style="animation-delay: 0.2s">
			<div class="stat-card card">
				<span class="label">Time Span</span>
				<span class="value"><span class="counter" data-target="1980" data-suffix=" – 2022">0</span></span>
			</div>
			<div class="stat-card card">
				<span class="label">Countries</span>
				<span class="value"><span class="counter" data-target="32" data-suffix=" OECD">0</span></span>
			</div>
			<div class="stat-card card">
				<span class="label">Observations</span>
				<span class="value">~<span class="counter" data-target="1200" data-separator="true">0</span></span>
			</div>
		</div>
	</div>

	<!-- Scrollytelling Section -->
	<section class="scrolly-section">
		<!-- The Sticky Visual Background -->
		<div class="scrolly-visual">
			<div id="visual-container" class="visual-box">
				<div id="vis-content" class="vis-inner">
					<span class="vis-placeholder">Scroll to explore...</span>
				</div>
			</div>
		</div>

		<!-- The Scrollable Text Steps -->
		<div class="scrolly-text">
			<div class="step-spacer">
				<article class="scrolly-step" data-step="1">
					<h2 style="color: #60a5fa;">Scene 1: The Globalization Shock</h2>
					<p>
						In the early 1990s, the KOF Globalization Index began an unprecedented parabolic ascent. Capital controls collapsed, trade barriers plummeted, and Western welfare democracies were suddenly exposed to the raw volatility of the global market.
					</p>
				</article>
			</div>
			
			<div class="step-spacer">
				<article class="scrolly-step" data-step="2">
					<h2 style="color: #f9fafb;">Scene 2: The Ideological Divergence</h2>
					<p>
						Academics were split. The <strong style="color:#f87171;">Efficiency Hypothesis</strong> claimed countries would race to the bottom, slashing social security transfers to remain competitive. The <strong style="color:#4ade80;">Compensation Hypothesis</strong> argued the exact opposite—that states must shield their citizens, expanding welfare to buy domestic peace.
					</p>
				</article>
			</div>

			<div class="step-spacer">
				<article class="scrolly-step" data-step="3">
					<h2 style="color: #818cf8;">Scene 3: The Empirical Reality</h2>
					<p>
						Our advanced panel Error Correction Models (ECM) reveal the truth: a robust, <strong style="color:#818cf8;">cointegrated long-run equilibrium</strong>. Social globalization and welfare spending are inextricably linked. There is no simple race to the bottom—the welfare state actively evolves to absorb external shocks.
					</p>
					<a href={`${base}/analysis`} class="cta-button" style="display:block; text-align:center; margin-top:1.5rem;">Explore Findings & Data &rarr;</a>
				</article>
			</div>
		</div>
	</section>

	<section class="methodology-preview container">
		<div class="glass-box card">
			<h2>Methodological Rigor</h2>
			<div class="method-steps">
				<div class="method-step-item">
					<span class="step-num">01</span>
					<h3>Advanced Panel FE</h3>
					<p>Controlling for country-specific intercepts and macroeconomic shocks.</p>
				</div>
				<div class="method-step-item">
					<span class="step-num">02</span>
					<h3>Dynamic Specs</h3>
					<p>Using lagged variables and stepwise robustness to ensure stability.</p>
				</div>
				<div class="method-step-item">
					<span class="step-num">03</span>
					<h3>Validation Suite</h3>
					<p>Hausman, RESET, and Granger tests to defend against endogeneity.</p>
				</div>
			</div>
		</div>
	</section>
</Layout>

<script is:inline>
	// ===== ANIMATED COUNTERS =====
	function animateCounters() {
		const counters = document.querySelectorAll('.counter');
		counters.forEach(counter => {
			const target = parseInt(counter.dataset.target, 10);
			const suffix = counter.dataset.suffix || '';
			const useSep = counter.dataset.separator === 'true';
			const duration = 1800;
			const startTime = performance.now();

			function easeOutQuart(t) { return 1 - Math.pow(1 - t, 4); }

			function update(now) {
				const elapsed = now - startTime;
				const progress = Math.min(elapsed / duration, 1);
				const current = Math.round(easeOutQuart(progress) * target);
				let display = useSep ? current.toLocaleString() : String(current);
				counter.textContent = display + suffix;
				if (progress < 1) requestAnimationFrame(update);
			}
			requestAnimationFrame(update);
		});
	}
	setTimeout(animateCounters, 400);

	// ===== SCROLLYTELLING =====
	const scrollySteps = document.querySelectorAll('.scrolly-step');
	const visualBox = document.getElementById('visual-container');
	const visContent = document.getElementById('vis-content');

	const visuals = {
		1: {
			color: 'rgba(59, 130, 246, 0.4)',
			border: '#3b82f6',
			html: `
				<div style="display:flex; flex-direction:column; align-items:center; justify-content:center; width:100%; height:100%; position:relative; padding:1.5rem;">
					<h3 style="font-size:1.75rem; font-weight:700; color:#60a5fa; margin-bottom:2rem; font-family:'Outfit',sans-serif;">KOFGI Breakout (1990s)</h3>
					<div style="width:70%; height:50%; border-bottom:2px solid #475569; border-left:2px solid #475569; position:relative; display:flex; align-items:flex-end;">
						<svg style="width:100%; height:100%; overflow:visible;" viewBox="0 0 100 100" preserveAspectRatio="none">
							<path class="path-anim" d="M 0,100 C 50,100 60,30 100,0" fill="none" stroke="#3b82f6" stroke-width="3" stroke-dasharray="250" stroke-dashoffset="250" stroke-linecap="round"/>
						</svg>
						<span style="position:absolute; bottom:-1.5rem; left:0; color:#64748b; font-family:monospace; font-size:0.8rem;">1980</span>
						<span style="position:absolute; bottom:-1.5rem; right:0; color:#60a5fa; font-family:monospace; font-size:0.8rem; font-weight:700;">2022</span>
					</div>
				</div>
			`
		},
		2: {
			color: 'rgba(239, 68, 68, 0.2)',
			border: '#ef4444',
			html: `
				<div style="display:flex; flex-direction:column; align-items:center; justify-content:center; width:100%; height:100%; position:relative;">
					<h3 style="font-size:1.75rem; font-weight:700; color:#d1d5db; margin-bottom:2rem; font-family:'Outfit',sans-serif;">The Dual Response</h3>
					<div style="display:flex; width:100%; align-items:center; justify-content:space-around; padding:0 2rem;">
						<div style="display:flex; flex-direction:column; align-items:center; color:#ef4444; gap:0.75rem;">
							<svg width="50" height="120" viewBox="0 0 24 100"><path d="M12 100L24 80H16V0H8V80H0L12 100Z" fill="currentColor"/></svg>
							<span style="font-weight:700; font-size:1rem; font-family:monospace; text-transform:uppercase; text-align:center;">Efficiency<br>(Retrench)</span>
						</div>
						<div style="display:flex; flex-direction:column; align-items:center; color:#22c55e; gap:0.75rem;">
							<span style="font-weight:700; font-size:1rem; font-family:monospace; text-transform:uppercase; text-align:center;">Compensation<br>(Expand)</span>
							<svg width="50" height="120" viewBox="0 0 24 100"><path d="M12 0L24 20H16V100H8V20H0L12 0Z" fill="currentColor"/></svg>
						</div>
					</div>
				</div>
			`
		},
		3: {
			color: 'rgba(99, 102, 241, 0.4)',
			border: '#818cf8',
			html: `
				<div style="display:flex; flex-direction:column; align-items:center; justify-content:center; width:100%; height:100%; position:relative;">
					<h3 style="font-size:1.75rem; font-weight:700; color:#818cf8; margin-bottom:1.5rem; font-family:'Outfit',sans-serif;">Stable Long-Run Equilibrium</h3>
					<div style="position:relative; width:200px; height:200px; display:flex; align-items:center; justify-content:center;">
						<div class="pulse-ring ring-1"></div>
						<div class="pulse-ring ring-2"></div>
						<div class="pulse-ring ring-3"></div>
						<div style="position:relative; z-index:2; color:#fff; font-weight:700; font-size:1.25rem; text-align:center; font-family:'Outfit',sans-serif; text-shadow:0 2px 8px rgba(0,0,0,0.6);">Cointegrated<br>Dynamics</div>
					</div>
				</div>
			`
		}
	};

	const observer = new IntersectionObserver((entries) => {
		entries.forEach(entry => {
			if (entry.isIntersecting) {
				const stepNum = entry.target.dataset.step;
				
				// Highlight active step, dim others
				scrollySteps.forEach(s => {
					s.style.opacity = '0.25';
					s.style.filter = 'blur(1px)';
					s.style.transform = 'scale(1)';
				});
				entry.target.style.opacity = '1';
				entry.target.style.filter = 'none';
				entry.target.style.transform = 'scale(1.02)';

				// Update Visual 
				const visData = visuals[stepNum];
				if (visData && visContent) {
					visContent.style.opacity = '0';
					
					setTimeout(() => {
						visualBox.style.boxShadow = '0 0 100px ' + visData.color;
						visualBox.style.borderColor = visData.border;
						visContent.innerHTML = visData.html;
						visContent.style.opacity = '1';
					}, 350);
				}
			}
		});
	}, {
		root: null,
		rootMargin: '-35% 0px -35% 0px',
		threshold: 0
	});

	setTimeout(() => {
		scrollySteps.forEach(step => observer.observe(step));
	}, 300);
</script>

<style>
	/* ===== HERO ===== */
	.hero {
		padding: 6rem 4rem;
		text-align: center;
		background: radial-gradient(circle at center, rgba(59, 130, 246, 0.15) 0%, transparent 70%);
	}

	.hero h1 {
		font-family: 'Outfit', sans-serif;
		font-weight: 800;
		max-width: 900px;
		margin-left: auto;
		margin-right: auto;
		background: linear-gradient(to bottom right, #fff 50%, rgba(255, 255, 255, 0.5));
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
	}

	.subtitle {
		font-size: 1.25rem;
		color: var(--text-secondary);
		max-width: 700px;
		margin: 0 auto 3rem;
	}

	.stats-row {
		display: flex;
		gap: 2rem;
		justify-content: center;
		flex-wrap: wrap;
	}

	.stat-card {
		padding: 1.5rem 2.5rem;
		min-width: 200px;
	}

	.stat-card .label {
		display: block;
		font-size: 0.875rem;
		color: var(--accent-primary);
		font-weight: 600;
		text-transform: uppercase;
		margin-bottom: 0.5rem;
	}

	.stat-card .value {
		font-family: 'Outfit', sans-serif;
		font-size: 1.5rem;
		font-weight: 700;
	}

	/* ===== SCROLLYTELLING ===== */
	.scrolly-section {
		position: relative;
		min-height: 300vh;
		width: 100%;
		margin-top: 4rem;
		margin-bottom: 4rem;
	}

	.scrolly-visual {
		position: sticky;
		top: 0;
		height: 100vh;
		width: 100%;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 2rem;
		pointer-events: none;
		z-index: 0;
	}

	.visual-box {
		position: relative;
		width: 100%;
		max-width: 800px;
		aspect-ratio: 16 / 10;
		border: 1px solid rgba(255, 255, 255, 0.1);
		border-radius: 1.5rem;
		background: rgba(15, 23, 42, 0.7);
		backdrop-filter: blur(12px);
		overflow: hidden;
		display: flex;
		align-items: center;
		justify-content: center;
		transition: box-shadow 0.8s ease, border-color 0.8s ease;
	}

	.vis-inner {
		width: 100%;
		height: 100%;
		display: flex;
		align-items: center;
		justify-content: center;
		transition: opacity 0.4s ease;
	}

	.vis-placeholder {
		color: #6b7280;
		font-family: monospace;
		font-size: 1.25rem;
		letter-spacing: 0.1em;
		animation: pulse-text 2s ease-in-out infinite;
	}

	@keyframes pulse-text {
		0%, 100% { opacity: 1; }
		50% { opacity: 0.4; }
	}

	.scrolly-text {
		position: relative;
		z-index: 10;
		max-width: 680px;
		margin: -100vh auto 0 auto;
		padding: 0 1.5rem 50vh 1.5rem;
	}

	.step-spacer {
		padding: 40vh 0;
	}

	.scrolly-step {
		padding: 2rem 2.5rem;
		background: rgba(15, 23, 42, 0.95);
		backdrop-filter: blur(16px);
		border-radius: 1rem;
		border: 1px solid rgba(59, 130, 246, 0.25);
		box-shadow: 0 8px 32px rgba(0, 0, 0, 0.5), 0 0 0 1px rgba(255,255,255,0.05) inset;
		transition: opacity 0.6s ease, filter 0.6s ease, transform 0.4s ease;
		opacity: 0.25;
		filter: blur(1px);
		pointer-events: auto;
	}

	.scrolly-step h2 {
		font-family: 'Outfit', sans-serif;
		font-size: 1.75rem;
		margin-bottom: 1rem;
	}

	.scrolly-step p {
		font-size: 1.1rem;
		line-height: 1.7;
		color: #d1d5db;
	}

	/* ===== PULSE RINGS (Scene 3 visual) ===== */
	.pulse-ring {
		position: absolute;
		border-radius: 50%;
		border: 4px solid;
		animation: pulse-grow 3s ease-in-out infinite;
	}
	.ring-1 { inset: 0;   border-color: #6366f1; animation-delay: 0s; }
	.ring-2 { inset: 20px; border-color: #60a5fa; animation-delay: 0.6s; }
	.ring-3 { inset: 40px; border-color: #34d399; animation-delay: 1.2s; }

	@keyframes pulse-grow {
		0%, 100% { transform: scale(1); opacity: 0.6; }
		50% { transform: scale(1.15); opacity: 1; }
	}

	/* ===== SVG PATH DRAW ===== */
	.path-anim {
		animation: draw-path 2.5s ease-out forwards;
	}
	@keyframes draw-path {
		to { stroke-dashoffset: 0; }
	}

	/* ===== CTA ===== */
	.cta-button {
		display: inline-block;
		margin-top: 2rem;
		padding: 0.75rem 1.5rem;
		background: var(--accent-primary);
		color: #fff;
		border-radius: 8px;
		font-weight: 600;
		transition: all 0.3s;
	}

	.cta-button:hover {
		background: var(--accent-secondary);
		transform: scale(1.05);
	}

	/* ===== METHODOLOGY ===== */
	.method-steps {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
		gap: 3rem;
		margin-top: 2rem;
	}

	.step-num {
		font-family: 'Outfit', sans-serif;
		font-size: 2.5rem;
		font-weight: 900;
		color: rgba(255, 255, 255, 0.05);
		line-height: 1;
		margin-bottom: -1rem;
		display: block;
	}

	/* ===== ENTRANCE ANIMATION ===== */
	.animate-in {
		opacity: 0;
		transform: translateY(20px);
		animation: slide-up 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
	}

	@keyframes slide-up {
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	/* ===== RESPONSIVE ===== */
	@media (max-width: 900px) {
		.hero {
			padding: 4rem 1rem;
		}
		.hero h1 { font-size: 2rem; }
		
		.scrolly-visual {
			position: relative;
			height: 50vh;
			top: auto;
			padding: 1rem;
			margin-bottom: -50vh;
		}

		.scrolly-step {
			margin: 40vh 0;
		}
	}
</style>
