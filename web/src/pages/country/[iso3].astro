---
import Layout from '../../layouts/Layout.astro';
import profiles from '../../../public/data/country_profiles.json';

export async function getStaticPaths() {
	// Generate a route for every ISO3 code
	return Object.keys(profiles).map((iso3) => {
		return {
			params: { iso3 },
			props: { profile: profiles[iso3] },
		};
	});
}

const { iso3 } = Astro.params;
const { profile } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;

// Compute some basic stats to display
const latestWelfare = profile.sstran[profile.sstran.length - 1];
const earliestWelfare = profile.sstran[0];
const welfareChange = (latestWelfare - earliestWelfare).toFixed(2);
const welfareChangeStr = welfareChange > 0 ? `+${welfareChange}` : welfareChange;

const latestKOFGI = profile.KOFGI[profile.KOFGI.length - 1];
const earliestKOFGI = profile.KOFGI[0];
const kofgiChange = (latestKOFGI - earliestKOFGI).toFixed(2);
const kofgiChangeStr = kofgiChange > 0 ? `+${kofgiChange}` : kofgiChange;

// --- Advanced Analytics ---
const obsCount = profile.sstran.filter(v => v !== null).length;
const reliability = obsCount >= 40 ? 'High' : obsCount >= 20 ? 'Moderate' : 'Limited';

// Theory Scorer (Simple heuristic)
const welfareDelta = latestWelfare - earliestWelfare;
const kofDelta = latestKOFGI - earliestKOFGI;
let theory = {
	name: 'Neutral / Stable',
	desc: 'This country shows a stable equilibrium between global integration and social policy, without clear evidence of racing-to-the-bottom or expansion.',
	icon: '⚖️',
	citation: 'Garrett (2001)'
};

if (kofDelta > 8) {
	if (welfareDelta > 1.5) {
		theory = {
			name: 'Compensation Hypothesis',
			desc: `Consistent with Rodrik (1998), ${profile.name} expanded social transfers as a buffer against external economic volatility from globalization.`,
			icon: '🛡️',
			citation: 'Rodrik (1998)'
		};
	} else if (welfareDelta < -1.5) {
		theory = {
			name: 'Efficiency Hypothesis',
			desc: `Aligned with the "Race-to-the-Bottom" theory, ${profile.name} appears to have reduced social spending under the pressure of international market competition.`,
			icon: '⚡',
			citation: 'Garrett (1998)'
		};
	}
}
---

<Layout title={`${profile.name} | Welfare & Globalization Profile`}>
	<div class="country-page">
		<!-- Breadcrumb Navigation -->
		<nav class="breadcrumb">
			<a href={`${baseUrl}/`}>Overview</a>
			<span class="sep">/</span>
			<a href={`${baseUrl}/map`}>Interactive Map</a>
			<span class="sep">/</span>
			<span class="current">{profile.name}</span>
		</nav>

		<div class="country-header">
			<div class="header-main">
				<h1>{profile.name}</h1>
				<div class={`reliability-badge ${reliability.toLowerCase()}`}>
					Reliability: {reliability}
				</div>
			</div>
			<p class="country-subtitle">Detailed Longitudinal Profile (1980 – 2022)</p>
		</div>

		<!-- Summary Cards -->
		<div class="summary-grid">
			<div class="card summary-card">
				<h3>Welfare Spending Trajectory</h3>
				<div class="stat-row">
					<span class="big-number">{latestWelfare}%</span>
					<span class={`change-badge ${Number(welfareChange) > 0 ? 'positive' : 'negative'}`}>
						{welfareChangeStr} pp since 1980
					</span>
				</div>
			</div>
			
			<div class="card summary-card">
				<h3>Globalization Index (KOFGI)</h3>
				<div class="stat-row">
					<span class="big-number">{latestKOFGI}</span>
					<span class={`change-badge ${Number(kofgiChange) > 0 ? 'positive' : 'negative'}`}>
						{kofgiChangeStr} pts since 1980
					</span>
				</div>
			</div>
		</div>

		<!-- AI Insight & Theory Section -->
		<div class="card insight-section">
			<div class="theory-card">
				<div class="theory-icon">{theory.icon}</div>
				<div class="theory-content">
					<div class="theory-label">Theory Match</div>
					<h3>{theory.name}</h3>
					<p>{theory.desc}</p>
					<div class="citation">Key Reference: <span class="cite-ref">{theory.citation}</span></div>
				</div>
			</div>
			<div class="narrative-box">
				<div class="box-label">Automated Profile Summary</div>
				<p>
					Since 1980, <strong>{profile.name}</strong> has experienced a {Math.abs(Number(kofgiChange)).toFixed(1)} point 
					{Number(kofgiChange) > 0 ? 'increase' : 'decrease'} in its Globalization Index. 
					During this same window, social security transfers shifted by {welfareChangeStr} percentage points. 
					This trajectory suggests {theory.name.toLowerCase()} dynamics, where social policy 
					{Number(welfareChange) > 0 ? 'expanded to buffer' : 'receded to accommodate'} modern global market integration.
				</p>
			</div>
		</div>

		<!-- Chart Section -->
		<div class="card chart-card">
			<h2>Historical Dynamics vs OECD Average</h2>
			<div id="country-chart" style="width:100%; height:500px;"></div>
		</div>
	</div>

	<script is:inline src="https://cdn.plot.ly/plotly-2.27.0.min.js"></script>

	<!-- Pass profile data to client script -->
	<script is:inline define:vars={{ profile }}>
		document.addEventListener('DOMContentLoaded', () => {
			const years = profile.years;
			
			// Traces for Welfare Spending (Left Y-Axis)
			const sstranTrace = {
				x: years,
				y: profile.sstran,
				name: `${profile.name} Welfare`,
				mode: 'lines',
				line: { color: '#3b82f6', width: 3 },
				yaxis: 'y1'
			};
			
			const oecdSstranTrace = {
				x: profile.oecd_avg.years,
				y: profile.oecd_avg.sstran,
				name: 'OECD Avg Welfare',
				mode: 'lines',
				line: { color: '#60a5fa', width: 2, dash: 'dash' },
				yaxis: 'y1'
			};

			// Traces for Globalization (Right Y-Axis)
			const kofgiTrace = {
				x: years,
				y: profile.KOFGI,
				name: `${profile.name} KOFGI`,
				mode: 'lines',
				line: { color: '#10b981', width: 3 },
				yaxis: 'y2'
			};

			const oecdKofgiTrace = {
				x: profile.oecd_avg.years,
				y: profile.oecd_avg.KOFGI,
				name: 'OECD Avg KOFGI',
				mode: 'lines',
				line: { color: '#34d399', width: 2, dash: 'dash' },
				yaxis: 'y2'
			};

			// Political & Policy Milestones
			const milestones = {
				'GBR': [
					{ year: 1980, label: 'Thatcherism' },
					{ year: 1993, label: 'ERM Crisis' },
					{ year: 2010, label: 'Austerity' }
				],
				'USA': [
					{ year: 1981, label: 'Reaganomics' },
					{ year: 1994, label: 'NAFTA' },
					{ year: 2008, label: 'GFC' }
				],
				'DEU': [
					{ year: 1990, label: 'Reunification' },
					{ year: 2003, label: 'Hartz Reforms' }
				],
				'SWE': [
					{ year: 1991, label: 'Fiscal Reform' },
					{ year: 1995, label: 'EU Entry' }
				],
				'DNK': [
					{ year: 1982, label: 'Schlüter Reforms' },
					{ year: 1993, label: 'Flexicurity' }
				],
				'FRA': [
					{ year: 1983, label: 'Tournant de la rigueur' },
					{ year: 1999, label: 'Euro Adoption' }
				]
			};

			const countryMilestones = milestones[iso3] || [];
			const shapes = countryMilestones.map(m => ({
				type: 'line',
				x0: m.year, x1: m.year,
				y0: 0, y1: 1, yref: 'paper',
				line: { color: 'rgba(255,255,255,0.2)', width: 1.5, dash: 'dot' }
			}));

			const annotations = countryMilestones.map(m => ({
				x: m.year, y: 1, yref: 'paper',
				text: m.label,
				showarrow: false,
				textangle: -90,
				xanchor: 'left',
				yanchor: 'top',
				font: { size: 10, color: '#94a3b8' },
				bgcolor: 'rgba(15,23,42,0.8)'
			}));

			const layout = {
				paper_bgcolor: 'rgba(0,0,0,0)',
				plot_bgcolor: 'rgba(0,0,0,0)',
				font: { color: '#f9fafb', family: 'Inter, sans-serif' },
				margin: { t: 20, r: 60, l: 60, b: 40 },
				legend: { orientation: 'h', y: -0.15, x: 0.5, xanchor: 'center' },
				hovermode: 'x unified',
				xaxis: {
					gridcolor: '#374151',
					title: 'Year'
				},
				yaxis: {
					title: 'Welfare Spending (% GDP)',
					titlefont: { color: '#3b82f6' },
					tickfont: { color: '#3b82f6' },
					gridcolor: '#374151',
					zeroline: false
				},
				yaxis2: {
					title: 'Globalization Index (0-100)',
					titlefont: { color: '#10b981' },
					tickfont: { color: '#10b981' },
					overlaying: 'y',
					side: 'right',
					gridcolor: 'transparent',
					zeroline: false
				},
				shapes: shapes,
				annotations: annotations
			};

			const config = { responsive: true, displayModeBar: false };
			
			Plotly.newPlot('country-chart', [sstranTrace, oecdSstranTrace, kofgiTrace, oecdKofgiTrace], layout, config);
		});
	</script>
</Layout>

<style>
	.country-page {
		padding: 2rem 3rem 3rem;
		max-width: 1200px;
		margin: 0 auto;
	}

	/* Breadcrumb */
	.breadcrumb {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		margin-bottom: 2rem;
		font-size: 0.9rem;
	}
	.breadcrumb a {
		color: #60a5fa;
		transition: color 0.2s;
	}
	.breadcrumb a:hover { color: #93bbfc; }
	.breadcrumb .sep { color: #4b5563; }
	.breadcrumb .current { color: #9ca3af; font-weight: 600; }

	/* Header */
	.country-header {
		margin-bottom: 2.5rem;
	}
	.country-header h1 {
		font-family: 'Outfit', sans-serif;
		font-size: 3rem;
		font-weight: 800;
		margin-bottom: 0.5rem;
	}
	.country-subtitle {
		color: #9ca3af;
		font-size: 1.1rem;
	}

	/* Summary Grid */
	.summary-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 1.5rem;
		margin-bottom: 2.5rem;
	}
	.summary-card h3 {
		color: #9ca3af;
		font-weight: 500;
		margin-bottom: 1rem;
		font-size: 0.95rem;
	}
	.stat-row {
		display: flex;
		align-items: baseline;
		gap: 0.75rem;
	}
	.big-number {
		font-size: 2.5rem;
		font-weight: 700;
		font-family: 'Outfit', sans-serif;
	}
	.change-badge {
		font-size: 0.8rem;
		font-weight: 600;
		padding: 0.25rem 0.75rem;
		border-radius: 999px;
	}
	.change-badge.positive {
		background: rgba(16, 185, 129, 0.15);
		color: #34d399;
	}
	.change-badge.negative {
		background: rgba(239, 68, 68, 0.15);
		color: #f87171;
	}

	/* Chart Card */
	.chart-card {
		padding: 2rem;
	}
	.chart-card h2 {
		font-family: 'Outfit', sans-serif;
		font-size: 1.5rem;
		margin-bottom: 1.5rem;
	}

	@media (max-width: 768px) {
		.country-page { padding: 1.5rem 1rem; }
		.summary-grid { grid-template-columns: 1fr; }
		.country-header h1 { font-size: 2rem; }
	}
	.country-header {
		margin-bottom: var(--spacing-lg);
	}
	.header-main {
		display: flex;
		align-items: center;
		gap: 1.5rem;
		margin-bottom: 0.5rem;
	}
	.reliability-badge {
		padding: 0.25rem 0.75rem;
		border-radius: 20px;
		font-size: 0.75rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}
	.reliability-badge.high { background: rgba(16, 185, 129, 0.1); color: #10b981; border: 1px solid rgba(16, 185, 129, 0.2); }
	.reliability-badge.moderate { background: rgba(245, 158, 11, 0.1); color: #f59e0b; border: 1px solid rgba(245, 158, 11, 0.2); }
	.reliability-badge.limited { background: rgba(239, 68, 68, 0.1); color: #ef4444; border: 1px solid rgba(239, 68, 68, 0.2); }

	.insight-section {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 2rem;
		margin-bottom: 2rem;
		padding: 2.5rem;
		background: rgba(15, 23, 42, 0.3);
		border-radius: 1.5rem;
	}
	.theory-card {
		display: flex;
		gap: 1.5rem;
		padding-right: 2rem;
		border-right: 1px solid rgba(255,255,255,0.05);
	}
	.theory-icon {
		font-size: 2.5rem;
		opacity: 0.8;
	}
	.theory-label, .box-label {
		font-size: 0.7rem;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: var(--accent-primary);
		font-weight: 700;
		margin-bottom: 0.5rem;
	}
	.theory-content h3 { margin-bottom: 0.75rem; color: #fff; }
	.theory-content p { font-size: 0.95rem; color: var(--text-secondary); line-height: 1.6; margin-bottom: 1rem; }
	.cite-ref { font-family: 'Outfit'; font-style: italic; color: #fff; }

	.narrative-box p {
		font-size: 1.05rem;
		line-height: 1.7;
		color: var(--text-secondary);
	}

	@media (max-width: 900px) {
		.insight-section { grid-template-columns: 1fr; }
		.theory-card { border-right: none; border-bottom: 1px solid rgba(255,255,255,0.05); padding-bottom: 2rem; padding-right: 0; }
	}
</style>
