---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Interactive Map | Midnight Econometrics">
	<main class="container mx-auto px-4 py-12">
		<div class="mb-12">
			<h1 class="text-4xl md:text-5xl font-bold mb-4 bg-gradient-to-r from-blue-400 to-indigo-400 bg-clip-text text-transparent">
				Geographic Deep Dive
			</h1>
			<p class="text-gray-400 max-w-2xl text-lg">
				Explore the evolution of welfare states and globalization across 32 OECD countries from 1980 to 2023. 
				Use the slider to see how policies shifted over four decades.
			</p>
		</div>

		<div class="glass-card mb-8">
			<div class="flex flex-wrap items-center justify-between mb-6 gap-4">
				<div class="flex items-center gap-4 bg-navy-900/50 p-2 rounded-xl border border-white/5">
					<button id="view-sstran" class="px-4 py-2 rounded-lg bg-blue-600 text-white font-medium transition-all shadow-lg shadow-blue-500/20 active-toggle">
						Welfare Spending
					</button>
					<button id="view-kofgi" class="px-4 py-2 rounded-lg text-gray-400 hover:text-white transition-all">
						Globalization (KOF)
					</button>
				</div>
                <div class="text-right">
                    <span id="current-year-display" class="text-3xl font-mono font-bold text-blue-400">2023</span>
                </div>
			</div>

			<div id="choropleth-map" style="height: 600px;" class="rounded-xl overflow-hidden">
                <!-- Plotly will render here -->
                <div class="h-full w-full flex items-center justify-center bg-navy-900/40 animate-pulse">
                    <span class="text-gray-500 font-mono">Initializing Neural Map...</span>
                </div>
            </div>
		</div>

		<div class="grid md:grid-cols-2 gap-8">
			<div class="glass-card p-6">
				<h3 class="text-xl font-bold mb-3 flex items-center gap-2">
					<span class="text-blue-400">📊</span> Legend & Scale
				</h3>
				<p class="text-gray-400 text-sm leading-relaxed">
					Welfare spending is measured as <strong>Social Security Transfers</strong> (percentage of GDP). 
					Globalization is represented by the <strong>KOF Overall Index</strong> (0-100 scale). 
					Darker regions indicate higher intensity in the selected metric.
				</p>
			</div>
			<div class="glass-card p-6">
				<h3 class="text-xl font-bold mb-3 flex items-center gap-2">
					<span class="text-indigo-400">💡</span> Insight
				</h3>
				<p class="text-gray-400 text-sm leading-relaxed">
					Observe the "dual movement" of the 1990s: globalization accelerated rapidly in Central Europe while welfare spending 
					began its long-term divergence between Liberal and Social Democratic regimes.
				</p>
			</div>
		</div>
	</main>
</Layout>

	<!-- Plotly.js CDN -->
	<script is:inline src="https://cdn.plot.ly/plotly-2.27.0.min.js"></script>

	<script is:inline>
	let mapData = [];
	let currentVar = 'sstran';
	let currentYear = 2023;

	async function initMap() {
		try {
			const response = await fetch('/economics-of-the-welfare-state/data/map_data.json');
			mapData = await response.json();
			
			renderMap();
			setupListeners();
		} catch (err) {
			console.error("Failed to load map data:", err);
		}
	}

	function renderMap() {
		const filteredData = mapData.filter(d => d.year === currentYear);
		const locations = filteredData.map(d => d.iso3);
		const z = filteredData.map(d => d[currentVar]);
		const text = filteredData.map(d => `${d.iso3}: ${d[currentVar].toFixed(2)}`);

		const data = [{
			type: 'choropleth',
			locations: locations,
			z: z,
			text: text,
			colorscale: currentVar === 'sstran' ? 'Viridis' : 'Plasma',
			autocolorscale: false,
			reversescale: true,
			marker: {
				line: {
					color: 'rgb(255,255,255, 0.1)',
					width: 0.5
				}
			},
			colorbar: {
				title: currentVar === 'sstran' ? '% GDP' : 'Index',
				thickness: 15,
				bgcolor: 'rgba(0,0,0,0)',
				tickfont: { color: '#94a3b8' },
				titlefont: { color: '#cbd5e1' }
			}
		}];

		const layout = {
			geo: {
				projection: { type: 'robinson' },
				showframe: false,
				showcoastlines: true,
				coastlinecolor: 'rgba(255,255,255,0.1)',
				bgcolor: 'rgba(0,0,0,0)',
				lakecolor: '#0f172a',
				showocean: true,
				oceancolor: '#020617'
			},
			margin: { l: 0, r: 0, t: 0, b: 0 },
			paper_bgcolor: 'rgba(0,0,0,0)',
			plot_bgcolor: 'rgba(0,0,0,0)',
			dragmode: false
		};

		const config = {
			responsive: true,
			displayModeBar: false
		};

		Plotly.newPlot('choropleth-map', data, layout, config);
	}

	function setupListeners() {
		const btnSstran = document.getElementById('view-sstran');
		const btnKofgi = document.getElementById('view-kofgi');
		const yearDisplay = document.getElementById('current-year-display');

		btnSstran.addEventListener('click', () => {
			currentVar = 'sstran';
			toggleButtons(btnSstran, btnKofgi);
			renderMap();
		});

		btnKofgi.addEventListener('click', () => {
			currentVar = 'KOFGI';
			toggleButtons(btnKofgi, btnSstran);
			renderMap();
		});

		// Listen to global layout events if we had a shared slider, 
		// but since we want high performance, let's add the slider logic here
        // We'll use a Plotly slider for the smoothest experience
        updateMapWithSlider();
	}

	function toggleButtons(active, inactive) {
		active.classList.add('bg-blue-600', 'text-white', 'shadow-lg', 'shadow-blue-500/20');
		active.classList.remove('text-gray-400');
		inactive.classList.remove('bg-blue-600', 'text-white', 'shadow-lg', 'shadow-blue-500/20');
		inactive.classList.add('text-gray-400');
	}

    function updateMapWithSlider() {
        const years = Array.from({length: 2023 - 1980 + 1}, (_, i) => 1980 + i);
        
        const frames = years.map(year => {
            const filtered = mapData.filter(d => d.year === year);
            return {
                name: year.toString(),
                data: [{
                    locations: filtered.map(d => d.iso3),
                    z: filtered.map(d => d[currentVar]),
                    text: filtered.map(d => `${d.iso3}: ${d[currentVar].toFixed(2)}`)
                }]
            };
        });

        const sliders = [{
            pad: { t: 60 },
            currentvalue: {
                visible: true,
                prefix: 'Year: ',
                xanchor: 'right',
                font: { size: 20, color: '#60a5fa' }
            },
            steps: years.map(year => ({
                label: year.toString(),
                method: 'animate',
                args: [[year.toString()], {
                    mode: 'immediate',
                    transition: { duration: 300 },
                    frame: { duration: 300, redraw: true }
                }]
            }))
        }];

        Plotly.relayout('choropleth-map', { sliders: sliders });
        Plotly.addFrames('choropleth-map', frames);
    }

	initMap();
</script>

<style>
	.glass-card {
		background: rgba(15, 23, 42, 0.6);
		backdrop-filter: blur(12px);
		border: 1px solid rgba(255, 255, 255, 0.1);
		border-radius: 1.5rem;
		padding: 2rem;
	}
</style>
