---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;
---

<Layout title="Interactive Map | Midnight Econometrics">
	<main class="map-page container">
		<header class="page-header">
			<h1 class="gradient-text text-glow">Geographic Deep Dive</h1>
			<p class="subtitle">
				Explore the evolution of welfare states and globalization across 32 OECD countries from 1980 to 2023. 
				Use the slider to see how policies shifted over four decades.
			</p>
		</header>

		<div class="card map-card">
			<div class="map-controls">
				<div class="toggle-group">
					<button id="view-sstran" class="toggle-btn active">
						Welfare Spending
					</button>
					<button id="view-kofgi" class="toggle-btn">
						Globalization (KOF)
					</button>
				</div>
                <div class="playback-controls">
                    <button id="play-btn" class="play-btn" aria-label="Play Animation">
                        <span class="play-icon">▶</span>
                        <span class="pause-icon" style="display:none">Ⅱ</span>
                    </button>
                    <input type="range" id="year-slider" min="1980" max="2023" step="1" value="2023" class="temporal-slider" />
                    <span id="current-year-display" class="year-badge">2023</span>
                </div>
			</div>

			<div id="choropleth-map" class="map-viewport">
                <!-- Plotly will render here -->
                <div class="map-loading">
                    <span class="loading-text">Initializing Neural Map...</span>
                </div>
            </div>
		</div>

		<div class="insight-grid">
			<div class="card insight-card">
				<h3>
					<span class="icon">📊</span> Legend & Scale
				</h3>
				<p>
					Welfare spending is measured as <strong>Social Security Transfers</strong> (percentage of GDP). 
					Globalization is represented by the <strong>KOF Overall Index</strong> (0-100 scale). 
					Darker regions indicate higher intensity in the selected metric.
				</p>
			</div>
			<div class="card insight-card">
				<h3>
					<span class="icon">💡</span> Insight
				</h3>
				<p>
					Observe the "dual movement" of the 1990s: globalization accelerated rapidly in Central Europe while welfare spending 
					began its long-term divergence between Liberal and Social Democratic regimes.
				</p>
			</div>
		</div>
	</main>
</Layout>

	<!-- Plotly.js CDN -->
	<script is:inline src="https://cdn.plot.ly/plotly-2.27.0.min.js"></script>

	<script is:inline define:vars={{ base }}>
	let mapData = [];
	let currentVar = 'sstran';
	let currentYear = 2023;

	async function initMap() {
		try {
			const response = await fetch(`${base}/data/map_data.json`);
			mapData = await response.json();
			
			renderMap();
			setupListeners();

			// Hide loader after initial render
			const loader = document.querySelector('.map-loading');
			if (loader) loader.style.display = 'none';
		} catch (err) {
			console.error("Failed to load map data:", err);
		}
	}

	function renderMap() {
		const filteredData = mapData.filter(d => d.year === currentYear);
		const locations = filteredData.map(d => d.iso3);
		const z = filteredData.map(d => d[currentVar]);
		const text = filteredData.map(d => `${d.iso3}: ${d[currentVar].toFixed(2)}`);

		const data = [{
			type: 'choropleth',
			locations: locations,
			z: z,
			text: text,
			colorscale: currentVar === 'sstran' ? 'Viridis' : 'Plasma',
			autocolorscale: false,
			reversescale: true,
			marker: {
				line: {
					color: 'rgb(255,255,255, 0.1)',
					width: 0.5
				}
			},
			colorbar: {
				title: currentVar === 'sstran' ? '% GDP' : 'Index',
				thickness: 15,
				bgcolor: 'rgba(0,0,0,0)',
				tickfont: { color: '#94a3b8' },
				titlefont: { color: '#cbd5e1' }
			}
		}];

		const layout = {
			geo: {
				projection: { type: 'robinson' },
				showframe: false,
				showcoastlines: true,
				coastlinecolor: 'rgba(255,255,255,0.1)',
				bgcolor: 'rgba(0,0,0,0)',
				lakecolor: '#0f172a',
				showocean: true,
				oceancolor: '#020617'
			},
			margin: { l: 0, r: 0, t: 0, b: 0 },
			paper_bgcolor: 'rgba(0,0,0,0)',
			plot_bgcolor: 'rgba(0,0,0,0)',
			dragmode: false
		};

		const config = {
			responsive: true,
			displayModeBar: false
		};

		Plotly.newPlot('choropleth-map', data, layout, config);
	}

		// Navigation
		myPlot.on('plotly_click', function(data) {
			if (data.points && data.points.length > 0) {
				const iso3 = data.points[0].location;
				window.location.href = `${base}/country/${iso3}`;
			}
		});

		const btnSstran = document.getElementById('view-sstran');
		const btnKofgi = document.getElementById('view-kofgi');
		const slider = document.getElementById('year-slider');
		const playBtn = document.getElementById('play-btn');
		const yearDisplay = document.getElementById('current-year-display');

		let isPlaying = false;
		let playInterval;

		btnSstran.addEventListener('click', () => {
			currentVar = 'sstran';
			toggleButtons(btnSstran, btnKofgi);
			renderMap();
		});

		btnKofgi.addEventListener('click', () => {
			currentVar = 'KOFGI';
			toggleButtons(btnKofgi, btnSstran);
			renderMap();
		});

		// Slider Logic
		slider.addEventListener('input', (e) => {
			currentYear = parseInt(e.target.value);
			yearDisplay.innerText = currentYear;
			renderMap();
		});

		// Playback Logic
		playBtn.addEventListener('click', () => {
			isPlaying = !isPlaying;
			const playIcon = playBtn.querySelector('.play-icon');
			const pauseIcon = playBtn.querySelector('.pause-icon');

			if (isPlaying) {
				playIcon.style.display = 'none';
				pauseIcon.style.display = 'inline';
				playInterval = setInterval(() => {
					currentYear++;
					if (currentYear > 2023) currentYear = 1980;
					slider.value = currentYear;
					yearDisplay.innerText = currentYear;
					renderMap();
				}, 350);
			} else {
				playIcon.style.display = 'inline';
				pauseIcon.style.display = 'none';
				clearInterval(playInterval);
			}
		});
	}

	function toggleButtons(active, inactive) {
		active.classList.add('active');
		inactive.classList.remove('active');
	}

	initMap();
</script>

<style>
	.map-page {
		padding: var(--spacing-xl) 0;
	}

	.page-header {
		margin-bottom: 3rem;
	}

	.gradient-text {
		font-size: clamp(2.5rem, 8vw, 3.5rem);
		font-weight: 800;
		background: linear-gradient(to right, #60a5fa, #818cf8);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		font-family: 'Outfit', sans-serif;
		margin-bottom: 0.5rem;
	}

	.subtitle {
		color: var(--text-secondary);
		max-width: 600px;
		font-size: 1.1rem;
		line-height: 1.6;
	}

	.map-card {
		padding: 2rem;
		margin-bottom: 3rem;
	}

	.map-controls {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 1.5rem 2rem;
		border-bottom: 1px solid rgba(255, 255, 255, 0.05);
		background: rgba(15, 23, 42, 0.2);
		flex-wrap: wrap;
		gap: 1.5rem;
	}

	.playback-controls {
		display: flex;
		align-items: center;
		gap: 1.25rem;
		flex: 1;
		justify-content: flex-end;
		max-width: 600px;
	}

	.year-badge {
		font-family: 'Outfit', sans-serif;
		font-size: 1.5rem;
		font-weight: 700;
		color: var(--accent-primary);
		min-width: 70px;
		text-align: right;
		text-shadow: 0 0 15px rgba(59, 130, 246, 0.3);
	}

	.play-btn {
		background: var(--accent-primary);
		color: #fff;
		border: none;
		width: 40px;
		height: 40px;
		border-radius: 50%;
		display: flex;
		align-items: center;
		justify-content: center;
		cursor: pointer;
		font-size: 1rem;
		transition: all 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275);
		box-shadow: 0 4px 15px rgba(59, 130, 246, 0.4);
	}
	.play-btn:hover { transform: scale(1.1); background: #60a5fa; }
	.play-btn:active { transform: scale(0.95); }

	.temporal-slider {
		flex: 1;
		height: 6px;
		appearance: none;
		background: #1e293b;
		border-radius: 4px;
		outline: none;
	}
	.temporal-slider::-webkit-slider-thumb {
		appearance: none;
		width: 20px;
		height: 20px;
		background: #fff;
		border: 4px solid var(--accent-primary);
		border-radius: 50%;
		cursor: pointer;
		box-shadow: 0 0 10px rgba(0,0,0,0.5);
		transition: transform 0.2s;
	}
	.temporal-slider::-webkit-slider-thumb:hover { transform: scale(1.2); }

	.toggle-group {
		display: flex;
		background: rgba(15, 23, 42, 0.4);
		padding: 0.4rem;
		border-radius: 12px;
		border: 1px solid rgba(255, 255, 255, 0.05);
	}

	.toggle-btn {
		padding: 0.75rem 1.5rem;
		border-radius: 8px;
		border: none;
		background: transparent;
		color: #94a3b8;
		font-weight: 600;
		cursor: pointer;
		transition: all 0.3s ease;
	}

	.toggle-btn:not(.active):hover {
		color: #cbd5e1;
		background: rgba(255, 255, 255, 0.03);
	}

	.toggle-btn.active {
		background: var(--accent-primary);
		color: #fff;
		box-shadow: 0 4px 12px rgba(59, 130, 246, 0.4);
	}

	.year-text {
		font-family: 'Outfit', monospace;
		font-size: 2.5rem;
		font-weight: 700;
		color: var(--accent-primary);
		text-shadow: 0 0 20px rgba(59, 130, 246, 0.3);
	}

	.map-viewport {
		height: 600px;
		border-radius: 1rem;
		overflow: hidden;
		background: rgba(15, 23, 42, 0.2);
		position: relative;
	}

	.map-loading {
		position: absolute;
		inset: 0;
		display: flex;
		align-items: center;
		justify-content: center;
		background: rgba(15, 23, 42, 0.4);
		animation: pulse 2s infinite;
	}

	.loading-text {
		color: var(--text-muted);
		font-family: monospace;
	}

	.insight-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
		gap: 2rem;
	}

	.insight-card h3 {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		margin-bottom: 1rem;
	}

	.insight-card p {
		color: var(--text-secondary);
		font-size: 0.95rem;
		line-height: 1.6;
	}

	@keyframes pulse {
		0%, 100% { opacity: 1; }
		50% { opacity: 0.5; }
	}

	@media (max-width: 768px) {
		.map-viewport { height: 450px; }
		.toggle-group { width: 100%; }
		.toggle-btn { flex: 1; }
		.year-right { width: 100%; text-align: center; }
	}
</style>
