---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;
---

<Layout title="Appendix | Detailed Econometric Results">
	<div class="appendix-header container">
		<h1>Econometric Appendix</h1>
		<p class="subtitle">
			Comprehensive diagnostic tables, summary statistics, and stationarity results 
			supporting the core findings of the paper.
		</p>
	</div>

	<section class="appendix-container container">
		<div class="card intro-card">
			<p>
				Below are the full diagnostic results for all 32 OECD countries across the 1980–2022 period.
				These tables match the results in the final research paper's appendix.
			</p>
			
			<div class="table-nav">
				<a href="#summary-stats" class="pill">Summary Stats</a>
				<a href="#vif-results" class="pill">VIF (Multicollinearity)</a>
				<a href="#regression-results" class="pill text-blue-400 border-blue-400">Dynamic Regression Table</a>
			</div>
		</div>

		<!-- Summary Stats Table -->
		<div id="summary-stats" class="card table-card">
			<div class="card-header">
				<h2>Table A1: Summary Statistics</h2>
			</div>
			<div class="table-responsive">
				<table id="summary-table" class="premium-table">
					<thead>
						<tr>
							<th>Variable</th>
							<th>N</th>
							<th>Mean</th>
							<th>Std</th>
							<th>Min</th>
							<th>Max</th>
						</tr>
					</thead>
					<tbody id="summary-body">
						<!-- Populated by JS -->
					</tbody>
				</table>
			</div>
		</div>

		<!-- VIF Table (Hardcoded for first-load speed, matches Python output) -->
		<div id="vif-results" class="card table-card">
			<div class="card-header">
				<h2>Table A2: Variance Inflation Factor (VIF)</h2>
			</div>
			<div class="table-responsive">
				<table class="premium-table">
					<thead>
						<tr>
							<th>Variable</th>
							<th>Overall</th>
							<th>Economic</th>
							<th>Social</th>
							<th>Political</th>
						</tr>
					</thead>
					<tbody>
						<tr><td>KOF Indices</td><td>1.53</td><td>1.37</td><td>2.13</td><td>2.18</td></tr>
						<tr><td>ln(GDP pc)</td><td>1.44</td><td>1.24</td><td>1.78</td><td>1.25</td></tr>
						<tr><td>Inflation</td><td>1.03</td><td>1.03</td><td>1.04</td><td>1.02</td></tr>
						<tr><td>Deficit</td><td>1.41</td><td>1.39</td><td>1.40</td><td>1.39</td></tr>
						<tr><td>Debt</td><td>1.66</td><td>1.64</td><td>1.64</td><td>1.70</td></tr>
						<tr><td>ln(Population)</td><td>1.30</td><td>1.42</td><td>1.44</td><td>2.13</td></tr>
						<tr><td>Dependency Ratio</td><td>1.23</td><td>1.24</td><td>1.30</td><td>1.20</td></tr>
					</tbody>
				</table>
			</div>
			<div class="table-footer">
				<p>Note: VIF &lt; 5 indicates no severe multicollinearity concerns.</p>
			</div>
		</div>

		<!-- Dynamic Master Regression Table -->
		<div id="regression-results" class="card table-card">
			<div class="card-header flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
				<h2>Table A3: Interactive Regression Results</h2>
				<div class="flex bg-navy-900/50 p-1 rounded-lg border border-white/5">
					<button id="btn-clustered" class="px-4 py-2 rounded-md bg-blue-600 text-white font-medium text-sm transition-all shadow-lg active">
						Standard Clustered SE
					</button>
					<button id="btn-dk" class="px-4 py-2 rounded-md text-gray-400 hover:text-white text-sm transition-all">
						Driscoll-Kraay Robust SE
					</button>
				</div>
			</div>
			<div class="table-responsive" style="margin-top: 0;">
				<table class="premium-table regression-table flex-table">
					<thead>
						<tr>
							<th style="width: 25%">Variable</th>
							<th>(1)<br/>Overall</th>
							<th>(2)<br/>Economic</th>
							<th>(3)<br/>Social</th>
							<th>(4)<br/>Political</th>
						</tr>
					</thead>
					<tbody id="regression-body">
						<tr><td colspan="5" class="text-center py-8">Loading regression data...</td></tr>
					</tbody>
				</table>
			</div>
			<div class="table-footer mt-4">
				<p>Significance levels: * p&lt;0.10, ** p&lt;0.05, *** p&lt;0.01. Standard errors in parentheses.</p>
			</div>
		</div>
	</section>

	<script is:inline define:vars={{ base }}>
		async function initAppendix() {
			try {
				const summaryRes = await fetch(`${base}/data/summary_stats.json`);
				const summaryData = await summaryRes.json();
				const summaryBody = document.getElementById('summary-body');

				summaryBody.innerHTML = Object.entries(summaryData).map(([varName, stats]) => `
					<tr>
						<td><strong>${varName}</strong></td>
						<td>${stats.count}</td>
						<td>${stats.mean}</td>
						<td>${stats.std}</td>
						<td>${stats.min}</td>
						<td>${stats.max}</td>
					</tr>
				`).join('');
			} catch (err) {
				console.error("Failed to load summary stats:", err);
			}

			try {
				const regRes = await fetch(`${base}/data/master_table.json`);
				const regData = await regRes.json();
				
				let currentSeType = 'clustered'; // 'clustered' or 'dk'
				const models = ['KOFGI', 'KOFEcGI', 'KOFSoGI', 'KOFPoGI'];
				
				// Extract all unique variables
				const allVarsMap = new Map();
				models.forEach(model => {
					if (regData[model] && regData[model].variables) {
						regData[model].variables.forEach(v => {
							allVarsMap.set(v.variable, v.label);
						});
					}
				});
				
				// Sort to put indices first, then controls, then constant
				const uniqueVars = Array.from(allVarsMap.keys()).sort((a, b) => {
					if (a.includes('KOF')) return -1;
					if (b.includes('KOF')) return 1;
					if (a === 'const') return 1;
					if (b === 'const') return -1;
					return 0;
				});

				const renderRegressionTable = () => {
					const tbody = document.getElementById('regression-body');
					let html = '';
					
					// Main Coefficients
					uniqueVars.forEach(vName => {
						const label = allVarsMap.get(vName);
						
						// Coef row
						html += `<tr><td><strong>${label}</strong></td>`;
						models.forEach(model => {
							const vData = regData[model]?.variables.find(v => v.variable === vName);
							if (vData) {
								const stars = vData[currentSeType].stars;
								html += `<td>${vData.coef.toFixed(3)}${stars}</td>`;
							} else {
								html += `<td></td>`;
							}
						});
						html += `</tr>`;
						
						// SE row
						html += `<tr class="se-row"><td class="text-sm"></td>`;
						models.forEach(model => {
							const vData = regData[model]?.variables.find(v => v.variable === vName);
							if (vData) {
								html += `<td class="text-sm text-gray-400">(${vData[currentSeType].se.toFixed(3)})</td>`;
							} else {
								html += `<td></td>`;
							}
						});
						html += `</tr>`;
					});
					
					// Observations
					html += `<tr class="border-t border-gray-700 mt-2"><td><strong>N</strong></td>`;
					models.forEach(model => {
						html += `<td>${regData[model]?.nobs || ''}</td>`;
					});
					html += `</tr>`;

					// R-squared
					html += `<tr><td><strong>R-squared</strong></td>`;
					models.forEach(model => {
						html += `<td>${regData[model]?.rsquared.toFixed(3) || ''}</td>`;
					});
					html += `</tr>`;

					tbody.innerHTML = html;
				};

				// Toggle Logic
				const btnClustered = document.getElementById('btn-clustered');
				const btnDk = document.getElementById('btn-dk');
				
				btnClustered.addEventListener('click', () => {
					currentSeType = 'clustered';
					btnClustered.classList.add('bg-blue-600', 'text-white', 'shadow-lg');
					btnClustered.classList.remove('text-gray-400');
					btnDk.classList.remove('bg-blue-600', 'text-white', 'shadow-lg');
					btnDk.classList.add('text-gray-400');
					renderRegressionTable();
				});
				
				btnDk.addEventListener('click', () => {
					currentSeType = 'dk';
					btnDk.classList.add('bg-blue-600', 'text-white', 'shadow-lg');
					btnDk.classList.remove('text-gray-400');
					btnClustered.classList.remove('bg-blue-600', 'text-white', 'shadow-lg');
					btnClustered.classList.add('text-gray-400');
					renderRegressionTable();
				});

				renderRegressionTable();
				
			} catch (err) {
				console.error("Failed to load regression table data:", err);
				document.getElementById('regression-body').innerHTML = `<tr><td colspan="5" class="text-red-400">Error loading table data. Please re-run the Python export script.</td></tr>`;
			}
		}

		initAppendix();
	</script>
</Layout>

<style>
	.appendix-header {
		padding: var(--spacing-xl) var(--spacing-lg);
	}

	.appendix-container {
		display: flex;
		flex-direction: column;
		gap: 3rem;
		padding-bottom: var(--spacing-xl);
	}

	.table-nav {
		display: flex;
		gap: 1rem;
		margin-top: 1.5rem;
		flex-wrap: wrap;
	}

	.pill {
		padding: 0.5rem 1.25rem;
		background: rgba(255, 255, 255, 0.05);
		border: 1px solid var(--card-border);
		border-radius: 9999px;
		font-size: 0.875rem;
		color: var(--text-secondary);
		transition: all 0.2s;
	}

	.pill:hover {
		background: var(--accent-primary);
		color: #fff;
		border-color: var(--accent-primary);
	}

	.table-card {
		overflow: hidden;
	}

	.table-responsive {
		overflow-x: auto;
		margin: 1.5rem 0;
	}

	.premium-table {
		width: 100%;
		border-collapse: collapse;
		text-align: left;
		font-size: 0.9375rem;
	}

	.premium-table th {
		padding: 1rem;
		background: rgba(255, 255, 255, 0.03);
		color: var(--accent-primary);
		font-weight: 600;
		text-transform: uppercase;
		font-size: 0.75rem;
		letter-spacing: 0.05em;
		border-bottom: 2px solid var(--card-border);
	}

	.premium-table td {
		padding: 1rem;
		border-bottom: 1px solid var(--card-border);
		color: var(--text-secondary);
	}

	.premium-table tr:hover td {
		background: rgba(59, 130, 246, 0.02);
		color: #fff;
	}

	.table-footer {
		padding-top: 1rem;
		font-size: 0.875rem;
		color: var(--text-muted);
		font-style: italic;
	}

	.card-header h2 {
		font-family: 'Outfit', sans-serif;
		font-size: 1.5rem;
	}

	/* Dynamic Table Specifics */
	.regression-table th, .regression-table td {
		text-align: center;
	}
	.regression-table th:first-child, .regression-table td:first-child {
		text-align: left;
	}
	.se-row td {
		padding-top: 0;
		border-bottom: 1px solid var(--card-border);
	}
	.se-row:last-of-type td {
		border-bottom: 2px solid var(--card-border); /* Thicker line before stats */
	}
	tr:not(.se-row) td {
		border-bottom: none;
		padding-bottom: 0.25rem;
	}
</style>
