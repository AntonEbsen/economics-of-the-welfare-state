---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;
---

<Layout title="Analysis | Interactive Specification Curves">
	<div class="analysis-header container">
		<div>
			<h1>Econometric Analysis</h1>
			<p class="subtitle">
				Interactive results showing effect stability and model diagnostics across different specifications.
			</p>
		</div>
		<div class="header-actions">
			<button id="download-data-btn" class="export-btn secondary-btn">
				<svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a2 2 0 002 2h12a2 2 0 002-2v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg>
				Download Dataset
			</button>
			<button id="export-pdf-btn" class="export-btn">
				<svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
				Export Brief 
			</button>
		</div>
	</div>

	<section class="results-dashboard container">
		<!-- Main Specs Curve Section -->
		<div class="card spec-curve-card">
			<header class="card-header">
				<h2>
					<a href="#" data-glossary="robustness" class="glossary-link">Specification Curve</a>
				</h2>
				<div class="controls">
					<select id="index-select" class="styled-select">
						<option value="KOFGI">Overall Globalization (KOFGI)</option>
						<option value="KOFEcGI">Economic Globalization (KOFEcGI)</option>
						<option value="KOFSoGI">Social Globalization (KOFSoGI)</option>
						<option value="KOFPoGI">Political Globalization (KOFPoGI)</option>
					</select>
				</div>
			</header>
			
			<div class="robustness-explorer">
				<div class="explorer-label">Sensitivity Toggles:</div>
				<div id="control-toggles" class="toggle-group-grid">
					<!-- Populated by JS -->
				</div>
				<div class="explorer-footer">
					<span id="spec-count" class="badge">Showing all models</span>
					<button id="reset-filters" class="text-link">Reset Filters</button>
				</div>
			</div>

			<div id="plotly-chart" class="chart-viewport"></div>
			
			<footer class="chart-footer">
				<p><small>* Shaded area represents 95% Confidence Interval. Dots show the point estimate for each incremental control specification.</small></p>
			</footer>
		</div>

		<!-- Diagnostic & Insight Grid -->
		<div class="analysis-grid">
			<div class="card diagnostic-card">
				<h3>Model Health Index</h3>
				<div id="diagnostics-list" class="diag-list">
					<div class="loading">Analyzing indicators...</div>
				</div>
			</div>
			
			<div class="card summary-card">
				<h3>Quick Interpretation</h3>
				<div class="insight-pill">
					<span class="icon">✅</span>
					<div class="insight-text">
						<strong>Robustness:</strong> Globalization effects remain positive and significant across most specifications.
					</div>
				</div>
				<div class="insight-pill">
					<span class="icon">🔬</span>
					<div class="insight-text">
						<strong><a href="#" data-glossary="cointegration" class="glossary-link">Cointegration</a>:</strong> Long-run equilibrium is validated by Kao tests for all indices.
					</div>
				</div>
			</div>
		</div>

		<!-- Driver Analysis Section -->
		<div class="card driver-card">
			<header class="card-header">
				<h2>Driver Analysis (Variance Decomposition)</h2>
				<span class="badge badge-accent">Partial R² Contribution</span>
			</header>
			<div class="driver-layout">
				<div class="driver-chart-wrap">
					<div id="importance-chart" class="importance-chart"></div>
				</div>
				<div class="driver-sidebar">
					<div class="insight-pill">
						<span class="icon">🔍</span>
						<div class="insight-text">
							<strong>What drives welfare spending?</strong><br>
							This chart isolates how much unique variation is explained by each variable independently (Partial R-squared).
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<section class="simulator-section container">
		<div class="card simulator-card">
			<header class="card-header">
				<h2>Counterfactual Simulator</h2>
				<span class="badge badge-accent">Predictive Insight</span>
			</header>
			
			<div class="simulator-layout">
				<div class="sim-controls">
					<div class="control-group">
						<label for="country-sim-select">Target Country (Baseline 2023)</label>
						<select id="country-sim-select" class="styled-select w-full">
							<!-- Populated by JS -->
						</select>
					</div>

					<div class="control-group">
						<label for="shift-slider" class="shift-label">
							<span>Globalization Shift (Δ KOF)</span>
							<span id="shift-value" class="shift-value">+5.0</span>
						</label>
						<input type="range" id="shift-slider" min="-15" max="15" step="0.5" value="5" class="sim-range">
						<div class="range-labels">
							<span>-15 pts</span>
							<span>Baseline</span>
							<span>+15 pts</span>
						</div>
					</div>
				</div>

				<div class="sim-output">
					<div class="prediction-box">
						<span class="prediction-label">Predicted Welfare Impact</span>
						<div id="prediction-result" class="prediction-value">+1.24%</div>
						<p id="prediction-desc" class="prediction-desc">
							Based on robust coefficients, a 5-point increase in globalization 
							is predicted to shift spending for <span class="country-name font-bold">Denmark</span>.
						</p>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Plotly.js CDN -->
	<script is:inline src="https://cdn.plot.ly/plotly-2.27.0.min.js"></script>

	<script is:inline define:vars={{ base }}>
		function showFetchError(message) {
			const ids = ['diagnostics-list', 'plotly-chart', 'importance-chart'];
			for (const id of ids) {
				const el = document.getElementById(id);
				if (el) {
					el.innerHTML = `<div class="fetch-error" role="alert">⚠️ ${message}</div>`;
				}
			}
		}

		async function fetchJson(url) {
			const res = await fetch(url);
			if (!res.ok) {
				throw new Error(`${url}: ${res.status} ${res.statusText}`);
			}
			return res.json();
		}

		async function init() {
			let specData, diagData, simData, impData;
			try {
				[specData, diagData, simData, impData] = await Promise.all([
					fetchJson(`${base}/data/spec_curves.json`),
					fetchJson(`${base}/data/diagnostics.json`),
					fetchJson(`${base}/data/simulator.json`),
					fetchJson(`${base}/data/importance.json`),
				]);
			} catch (err) {
				console.error('Failed to load analysis data:', err);
				showFetchError(
					'Could not load analysis data. Run <code>econ-clean analyze</code> to regenerate the JSON fixtures, then refresh.'
				);
				return;
			}

			const select = document.getElementById('index-select');
			const diagList = document.getElementById('diagnostics-list');
			const toggleContainer = document.getElementById('control-toggles');
			const specCountBadge = document.getElementById('spec-count');
			
			const controlLabels = {
				'ln_gdppc': 'GDP per Capita',
				'inflation_cpi': 'Inflation',
				'deficit': 'Deficit',
				'debt': 'Debt',
				'ln_population': 'Population',
				'dependency_ratio': 'Dependency Ratio'
			};
			const allControls = Object.keys(controlLabels);
			const filters = {}; // { control: 'any' | 'included' | 'excluded' }

			function initToggles() {
				if (!toggleContainer) return;
				toggleContainer.innerHTML = allControls.map(ctrl => `
					<div class="ctrl-toggle-item">
						<label>${controlLabels[ctrl]}</label>
						<select data-ctrl="${ctrl}" class="mini-select">
							<option value="any">Any</option>
							<option value="included">Required</option>
							<option value="excluded">Excluded</option>
						</select>
					</div>
				`).join('');

				toggleContainer.querySelectorAll('select').forEach(sel => {
					sel.addEventListener('change', (e) => {
						filters[e.target.dataset.ctrl] = e.target.value;
						updateChart(select.value);
					});
				});
			}

			document.getElementById('reset-filters')?.addEventListener('click', () => {
				toggleContainer.querySelectorAll('select').forEach(sel => sel.value = 'any');
				Object.keys(filters).forEach(k => filters[k] = 'any');
				updateChart(select.value);
			});

			function updateChart(indexName) {
				let data = specData[indexName];
				if (!data) return;

				// Apply Filters from Omitted Variable Explorer
				const activeFilters = Object.entries(filters).filter(([_, v]) => v !== 'any');
				if (activeFilters.length > 0) {
					data = data.filter(d => {
						return activeFilters.every(([ctrl, val]) => {
							const isIncluded = d.included_controls.includes(ctrl);
							return val === 'included' ? isIncluded : !isIncluded;
						});
					});
				}

				if (specCountBadge) {
					specCountBadge.innerText = `Showing ${data.length} models`;
				}

				const x = data.map((_, i) => i);
				const y = data.map(d => d.coefficient);
				const lower = data.map(d => d.lower_ci);
				const upper = data.map(d => d.upper_ci);
				
				const labels = data.map((d, i) => {
					let ctrlStr = d.included_controls.join(', ');
					if (ctrlStr === "") ctrlStr = "None";
					return `<b>Rank ${i+1}</b><br>Coef: ${d.coefficient.toFixed(4)}<br>Controls: ${ctrlStr}`;
				});

				const trace = {
					x: x, y: y,
					mode: 'lines+markers',
					name: 'Coefficient',
					line: { color: '#3b82f6', width: 2 },
					marker: { size: 4, color: '#fff', line: { width: 1, color: '#3b82f6' } },
					text: labels,
					hovertemplate: '%{text}<extra></extra>',
					xaxis: 'x', yaxis: 'y'
				};

				const ciTrace = {
					x: x.concat(x.slice().reverse()),
					y: upper.concat(lower.slice().reverse()),
					fill: 'toself',
					fillcolor: 'rgba(59, 130, 246, 0.2)',
					line: { color: 'transparent' },
					name: '95% CI', hoverinfo: 'skip',
					xaxis: 'x', yaxis: 'y'
				};

				const gridX = [];
				const gridY = [];
				data.forEach((d, i) => {
					allControls.forEach(c => {
						if (d.included_controls.includes(c)) {
							gridX.push(i);
							gridY.push(controlLabels[c]);
						}
					});
				});

				const gridTrace = {
					x: gridX, y: gridY,
					mode: 'markers',
					marker: { symbol: 'square', size: 6, color: '#94a3b8' },
					hoverinfo: 'skip',
					xaxis: 'x', yaxis: 'y2'
				};

				const layout = {
					paper_bgcolor: 'rgba(0,0,0,0)',
					plot_bgcolor: 'rgba(0,0,0,0)',
					font: { color: '#f9fafb', family: 'Inter, sans-serif' },
					margin: { t: 40, r: 20, l: 150, b: 20 },
					showlegend: false,
					xaxis: { showticklabels: false, zeroline: false, showgrid: false, fixedrange: true },
					yaxis: { 
						title: 'Effect Size', gridcolor: '#374151', zerolinecolor: '#ef4444',
						domain: [0.45, 1], fixedrange: true
					},
					yaxis2: {
						domain: [0, 0.40],
						gridcolor: 'rgba(255,255,255,0.05)',
						tickfont: { size: 11, color: '#94a3b8' },
						fixedrange: true,
						categoryorder: 'array',
						categoryarray: Object.values(controlLabels).reverse()
					}
				};

				Plotly.newPlot('plotly-chart', [ciTrace, trace, gridTrace], layout, { responsive: true, displayModeBar: false });
			}

			function updateImportanceChart(indexName) {
				const data = impData[indexName];
				if (!data) return;
				const sortedData = [...data].reverse();
				const x = sortedData.map(d => d.partial_r2);
				const y = sortedData.map(d => d.label);
				const colors = sortedData.map(d => d.variable.includes(indexName) ? '#3b82f6' : '#475569');

				const trace = {
					type: 'bar', x: x, y: y,
					orientation: 'h',
					marker: { color: colors, border: { color: 'rgba(255,255,255,0.1)', width: 1 } },
					hovertemplate: '<b>%{y}</b><br>Partial R²: %{x:.2f}%<extra></extra>'
				};

				Plotly.newPlot('importance-chart', [trace], {
					paper_bgcolor: 'rgba(0,0,0,0)', plot_bgcolor: 'rgba(0,0,0,0)',
					font: { color: '#f9fafb', family: 'Inter, sans-serif' },
					margin: { t: 20, r: 20, l: 150, b: 40 },
					xaxis: { title: 'Partial R² Contribution (%)', gridcolor: '#374151', ticksuffix: '%' },
					yaxis: { gridcolor: 'transparent' }
				}, { responsive: true, displayModeBar: false });
			}

			function updateDiagnostics(indexName) {
				const diag = diagData.find(d => d.model === indexName);
				if (!diag) return;
				diagList.innerHTML = `
					<div class="diag-item"><span>Hausman Test</span><span class="badge ${diag.hausman_p < 0.05 ? 'badge-success' : 'badge-warning'}">${diag.hausman_preferred}</span></div>
					<div class="diag-item"><span>Serial Correlation</span><span class="badge ${diag.serial_corr_status === 'Clean' ? 'badge-success' : 'badge-error'}">${diag.serial_corr_status}</span></div>
					<div class="diag-item"><span>Observations</span><span class="badge badge-success">${diag.nobs}</span></div>
					<div class="diag-item"><span>R-squared</span><span class="badge badge-success">${diag.rsquared}</span></div>
				`;
			}

			function updateSimulator() {
				const iso3 = document.getElementById('country-sim-select').value;
				const idx = select.value;
				const deltaG = parseFloat(document.getElementById('shift-slider').value);
				const baselineWelfare = simData.baselines[iso3].sstran;
				const beta = simData.coefficients[idx].coef;
				const deltaPct = (beta * deltaG / baselineWelfare) * 100;
				
				document.getElementById('shift-value').textContent = (deltaG > 0 ? "+" : "") + deltaG.toFixed(1);
				const predictionResult = document.getElementById('prediction-result');
				predictionResult.className = `value ${deltaPct > 0 ? 'text-green-400' : 'text-red-400'} text-4xl font-bold font-mono`;
				predictionResult.textContent = (deltaPct > 0 ? "+" : "") + deltaPct.toFixed(2) + "%";
				
				document.getElementById('prediction-desc').innerHTML = `
					Based on the <span class="text-blue-400">Driscoll-Kraay</span> coefficients, a ${Math.abs(deltaG)} point 
					${deltaG >= 0 ? "increase" : "decrease"} in globalization (${idx}) is predicted to 
					${deltaPct >= 0 ? "expand" : "reduce"} welfare spending for 
					<span class="text-white font-bold">${iso3}</span> by ${Math.abs(deltaPct).toFixed(2)}%.
				`;
			}

			select.addEventListener('change', (e) => {
				updateChart(e.target.value);
				updateDiagnostics(e.target.value);
				updateImportanceChart(e.target.value);
				updateSimulator();
			});

			document.getElementById('country-sim-select').addEventListener('change', updateSimulator);
			document.getElementById('shift-slider').addEventListener('input', updateSimulator);

			// Initial Load
			initToggles();
			updateChart('KOFGI');
			updateDiagnostics('KOFGI');
			updateImportanceChart('KOFGI');
			updateSimulator();
		}

		init();
	</script>

	<!-- PDF Export Libraries (Phase 4.4) -->
	<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
	<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>

	<script is:inline>
		document.addEventListener('DOMContentLoaded', () => {
			const exportBtn = document.getElementById('export-pdf-btn');
			if (!exportBtn) return;

			exportBtn.addEventListener('click', async () => {
				const originalHTML = exportBtn.innerHTML;
				exportBtn.innerHTML = '<span style="animation:pulse 1s infinite">⏳ Generating...</span>';
				exportBtn.disabled = true;
				exportBtn.style.opacity = '0.7';

				try {
					const targetElement = document.querySelector('.results-dashboard');

					const canvas = await html2canvas(targetElement, {
						scale: 2,
						useCORS: true,
						backgroundColor: '#0f172a',
						windowWidth: targetElement.scrollWidth,
						windowHeight: targetElement.scrollHeight,
						logging: false
					});

					const { jsPDF } = window.jspdf;
					const pdf = new jsPDF({
						orientation: 'portrait',
						unit: 'pt',
						format: 'a4'
					});

					const pdfWidth = pdf.internal.pageSize.getWidth();
					const margin = 30;

					// Branded Header
					pdf.setFillColor(15, 23, 42);
					pdf.rect(0, 0, pdfWidth, 60, 'F');

					pdf.setFontSize(20);
					pdf.setTextColor(255, 255, 255);
					pdf.text('Midnight Econometrics', margin, 38);

					pdf.setFontSize(9);
					pdf.setTextColor(148, 163, 184);
					const dateStr = new Date().toLocaleString();
					pdf.text('Executive Brief | ' + dateStr, pdfWidth - margin, 38, { align: 'right' });

					// Add accent line
					pdf.setDrawColor(59, 130, 246);
					pdf.setLineWidth(2);
					pdf.line(margin, 62, pdfWidth - margin, 62);

					// Calculate image dimensions to fit width
					const imgWidth = pdfWidth - (margin * 2);
					const imgHeight = (canvas.height * imgWidth) / canvas.width;
					const imgData = canvas.toDataURL('image/jpeg', 0.95);

					// If the chart is taller than a single page, we need multi-page
					const maxImgHeight = pdf.internal.pageSize.getHeight() - 100;
					if (imgHeight <= maxImgHeight) {
						pdf.addImage(imgData, 'JPEG', margin, 80, imgWidth, imgHeight);
					} else {
						// Scale to fit single page
						const scaleFactor = maxImgHeight / imgHeight;
						pdf.addImage(imgData, 'JPEG', margin, 80, imgWidth * scaleFactor, maxImgHeight);
					}

					pdf.save('Midnight_Econometrics_Brief.pdf');

				} catch (error) {
					console.error("PDF generation failed:", error);
					alert("Failed to generate PDF. See console for details.");
				} finally {
					exportBtn.innerHTML = originalHTML;
					exportBtn.disabled = false;
					exportBtn.style.opacity = '1';
				}
			});
		});
	</script>
</Layout>

<style>
	.analysis-header {
		padding: var(--spacing-xl) var(--spacing-lg);
		text-align: left;
	}

	.header-actions {
		display: flex;
		gap: 1rem;
	}
	.secondary-btn {
		background: rgba(255, 255, 255, 0.05) !important;
		border: 1px solid rgba(255, 255, 255, 0.1) !important;
		color: var(--text-secondary) !important;
	}
	.secondary-btn:hover {
		background: rgba(255, 255, 255, 0.1) !important;
		border-color: rgba(255, 255, 255, 0.2) !important;
	}

	.glossary-link {
		color: inherit;
		text-decoration: underline dotted var(--accent-primary);
		cursor: help;
		transition: color 0.2s;
	}
	.glossary-link:hover {
		color: var(--accent-primary);
	}

	.robustness-explorer {
		background: rgba(15, 23, 42, 0.5);
		border: 1px solid rgba(255,255,255,0.05);
		border-radius: 12px;
		padding: 1.5rem;
		margin: 0 2rem 1.5rem;
	}
	.explorer-label {
		font-size: 0.75rem;
		text-transform: uppercase;
		color: var(--accent-primary);
		font-weight: 700;
		margin-bottom: 1rem;
		letter-spacing: 0.05em;
	}
	.toggle-group-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
		gap: 1rem;
		margin-bottom: 1rem;
	}
	.ctrl-toggle-item {
		display: flex;
		flex-direction: column;
		gap: 0.4rem;
	}
	.ctrl-toggle-item label {
		font-size: 0.8rem;
		color: var(--text-secondary);
	}
	.mini-select {
		background: #1e293b;
		color: #fff;
		border: 1px solid rgba(255,255,255,0.1);
		padding: 0.35rem 0.5rem;
		border-radius: 6px;
		font-size: 0.85rem;
		cursor: pointer;
	}
	.explorer-footer {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding-top: 1rem;
		border-top: 1px solid rgba(255,255,255,0.05);
	}
	.text-link {
		background: none;
		border: none;
		color: var(--accent-primary);
		font-size: 0.8rem;
		cursor: pointer;
		padding: 0;
		text-decoration: underline;
	}
	.badge {
		font-size: 0.75rem;
		background: rgba(59, 130, 246, 0.1);
		color: var(--accent-primary);
		padding: 0.2rem 0.6rem;
		border-radius: 4px;
	}

	.results-dashboard {
		display: flex;
		flex-direction: column;
		gap: 2rem;
		padding-bottom: var(--spacing-xl);
	}

	.card-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		margin-bottom: 2rem;
		border-bottom: 1px solid var(--card-border);
		padding-bottom: 1rem;
	}

	.styled-select {
		background: var(--bg-secondary);
		color: #fff;
		border: 1px solid var(--card-border);
		padding: 0.5rem 1rem;
		border-radius: 8px;
		font-family: inherit;
		cursor: pointer;
	}

	.chart-viewport {
		width: 100%;
		height: 600px;
		margin: 1.5rem 0;
	}

	.chart-footer {
		margin-top: 1rem;
		color: var(--text-muted);
		text-align: center;
	}

	.fetch-error {
		padding: 1.5rem;
		background: rgba(239, 68, 68, 0.08);
		border: 1px solid rgba(239, 68, 68, 0.25);
		border-radius: 8px;
		color: #fca5a5;
		font-size: 0.9rem;
		line-height: 1.5;
	}
	.fetch-error code {
		background: rgba(0, 0, 0, 0.3);
		padding: 0.1rem 0.35rem;
		border-radius: 4px;
		font-family: monospace;
		color: #fde68a;
	}

	/* Tooltip */
	.info-tooltip {
		display: inline-block;
		position: relative;
		margin-left: 0.5rem;
		vertical-align: middle;
	}
	.info-icon {
		cursor: help;
		opacity: 0.5;
		transition: opacity 0.2s;
		font-size: 0.9rem;
