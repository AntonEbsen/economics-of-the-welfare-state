---
import { ClientRouter } from 'astro:transitions';

interface Props {
	title: string;
}

const { title } = Astro.props;
import '../styles/global.css';
const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Economics of the Welfare State - Research Portal" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&family=Outfit:wght@500;700&display=swap" rel="stylesheet">
		<!-- Prevent flash of wrong theme -->
		<script is:inline>
			(function() {
				var t = localStorage.getItem('theme');
				if (t === 'light') document.documentElement.classList.add('light');
			})();
		</script>
		<ClientRouter />
	</head>
	<body>
		<div class="app-layout">
			<!-- Mobile Top Bar -->
			<header class="mobile-topbar" transition:persist>
				<button id="menu-toggle" class="menu-btn" aria-label="Toggle navigation">
					<span class="hamburger-line"></span>
					<span class="hamburger-line"></span>
					<span class="hamburger-line"></span>
				</button>
				<span class="mobile-title">EWS Research Portal</span>
			</header>
			<!-- Overlay for mobile -->
			<div id="sidebar-overlay" class="sidebar-overlay"></div>

			<aside id="sidebar" class="sidebar" transition:persist>
				<div class="sidebar-header">
					<div class="logo">EWS</div>
					<h2 class="project-title">Economics of<br/>the Welfare State</h2>
				</div>
				<nav class="main-nav">
					<a href={`${base}/`} class={`nav-item ${currentPath === base || currentPath === base + '/' ? 'active' : ''}`}>
						<span class="nav-icon">🏠</span>
						Overview
					</a>
					<a href={`${base}/analysis`} class={`nav-item ${currentPath.includes('/analysis') ? 'active' : ''}`}>
						<span class="nav-icon">📈</span>
						Analysis
					</a>
					<a href={`${base}/map`} class={`nav-item ${currentPath.includes('/map') ? 'active' : ''}`}>
						<span class="nav-icon">🌍</span>
						Interactive Map
					</a>
					<a href={`${base}/appendix`} class={`nav-item ${currentPath.includes('/appendix') ? 'active' : ''}`}>
						<span class="nav-icon">📚</span>
						Appendix
					</a>
					<div class="nav-divider"></div>
					<a href={`${base}/compare`} class={`nav-item ${currentPath.includes('/compare') ? 'active' : ''}`}>
						<span class="nav-icon">⚖️</span>
						Compare Tool
					</a>
					<a href={`${base}/methodology`} class={`nav-item ${currentPath.includes('/methodology') ? 'active' : ''}`}>
						<span class="nav-icon">📖</span>
						Methodology
					</a>
				</nav>
				<div class="sidebar-footer">
					<button id="theme-toggle" class="theme-toggle" aria-label="Toggle theme">
						<span class="theme-icon sun">☀️</span>
						<span class="theme-icon moon">🌙</span>
						<span class="theme-label">Light Mode</span>
					</button>
					<div class="authors-list">
						<p class="author">A. M. E. Jørgensen</p>
						<p class="author">Sheng Ye M. Chen</p>
						<p class="author">Jonas A. S. Nielsen</p>
					</div>
					<p class="status">Seminar Project 2026</p>
				</div>
			</aside>
			
			<main class="content">
				<slot />

				<!-- Global Footer -->
				<footer class="site-footer">
					<div class="footer-inner">
						<div class="footer-col">
							<h4>Midnight Econometrics</h4>
							<p>A research portal for exploring the relationship between globalization and welfare state dynamics across 32 OECD countries.</p>
						</div>
						<div class="footer-col">
							<h4>Data Sources</h4>
							<ul>
								<li><a href="https://kof.ethz.ch/en/forecasts-and-indicators/indicators/kof-globalisation-index.html" target="_blank" rel="noopener">KOF Globalisation Index (ETH Zürich)</a></li>
								<li><a href="https://www.oecd.org/social/expenditure.htm" target="_blank" rel="noopener">OECD Social Expenditure Database (SOCX)</a></li>
								<li><a href="https://data.worldbank.org/" target="_blank" rel="noopener">World Bank Development Indicators</a></li>
							</ul>
						</div>
						<div class="footer-col">
							<h4>Cite this Project</h4>
							<div class="citation-box">
								<p class="citation-text" id="citation-apa">
									Jørgensen, A. M. E., Chen, S. Y. M., & Nielsen, J. A. S. (2026). 
									<em>Economics of the Welfare State: A Longitudinal Analysis.</em>
								</p>
								<div class="citation-actions">
									<button class="btn-copy" onclick="navigator.clipboard.writeText(document.getElementById('citation-apa').innerText)">APA</button>
									<button class="btn-copy" id="btn-bibtex">BibTeX</button>
								</div>
								<div id="bibtex-content" style="display:none;">
{`@article{jorgensen2026welfare,
  title={Economics of the Welfare State: A Longitudinal Analysis},
  author={Jørgensen, Anton M. E. and Chen, Sheng Ye M. and Nielsen, Jonas A. S.},
  journal={University of Copenhagen Seminar Paper},
  year={2026}
}`}</div>
							</div>
						</div>
					</div>
					<div class="footer-bottom">
						<p>&copy; 2026 &middot; Anton M. E. Jørgensen, Sheng Ye M. Chen, Jonas A. S. Nielsen &middot; University of Copenhagen</p>
					</div>
				</footer>
			</main>
		</div>

		<!-- Glossary Drawer -->
		<div id="glossary-drawer" class="glossary-drawer">
			<div class="drawer-header">
				<h3 id="drawer-title">Term Definition</h3>
				<button id="close-drawer" class="close-btn">&times;</button>
			</div>
			<div class="drawer-body">
				<p id="drawer-definition" class="drawer-desc"></p>
				<div class="drawer-meta">
					<h4>How it applies:</h4>
					<p id="drawer-details"></p>
				</div>
				<a id="drawer-link" href="#" class="btn-more">Read Full Methodology &rarr;</a>
			</div>
		</div>

		<script is:inline>
			// Active nav highlighting
			const navItems = document.querySelectorAll('.nav-item');
			const currentPath = window.location.pathname;
			navItems.forEach(item => {
				const href = item.getAttribute('href');
				if (href === currentPath || href + '/' === currentPath ||
				    (href !== '/' && currentPath.startsWith(href))) {
					item.classList.add('active');
				}
			});

			// Mobile hamburger menu
			const menuBtn = document.getElementById('menu-toggle');
			const sidebar = document.getElementById('sidebar');
			const overlay = document.getElementById('sidebar-overlay');
			
			if (menuBtn && sidebar && overlay) {
				menuBtn.addEventListener('click', () => {
					sidebar.classList.toggle('open');
					overlay.classList.toggle('open');
					menuBtn.classList.toggle('open');
				});
				overlay.addEventListener('click', () => {
					sidebar.classList.remove('open');
					overlay.classList.remove('open');
					menuBtn.classList.remove('open');
				});
			}

			// Theme toggle
			const themeBtn = document.getElementById('theme-toggle');
			const themeLabel = themeBtn ? themeBtn.querySelector('.theme-label') : null;
			function updateThemeUI() {
				const isLight = document.documentElement.classList.contains('light');
				if (themeLabel) themeLabel.textContent = isLight ? 'Dark Mode' : 'Light Mode';
			}
			updateThemeUI();
			if (themeBtn) {
				themeBtn.addEventListener('click', () => {
					document.documentElement.classList.toggle('light');
					const isLight = document.documentElement.classList.contains('light');
					localStorage.setItem('theme', isLight ? 'light' : 'dark');
					updateThemeUI();
				});
			}

			// Glossary Logic
			const glossaryData = {
				ecm: {
					title: 'Error Correction Model (ECM)',
					def: 'A model used to estimate both short-run and long-run effects when variables share a stable relationship (cointegrated).',
					details: 'In this study, it captures how welfare spending adjusts when globalization shocks push it away from its long-run equilibrium.'
				},
				cointegration: {
					title: 'Cointegration',
					def: 'A long-term stochastic relationship between non-stationary variables.',
					details: 'We test for this to ensure that the correlation between globalization and welfare is not accidental (spurious) but theoretically anchored.'
				},
				robustness: {
					title: 'Specification Curve',
					def: 'A rigorous test of whether a finding holds true across many different modeling choices.',
					details: 'If the effect remains significant across 500+ different control combinations, we consider it highly robust.'
				}
			};

			const drawer = document.getElementById('glossary-drawer');
			const dTitle = document.getElementById('drawer-title');
			const dDef = document.getElementById('drawer-definition');
			const dDetails = document.getElementById('drawer-details');
			const dLink = document.getElementById('drawer-link');
			const closeDrawer = document.getElementById('close-drawer');

			window.openGlossary = (id) => {
				const term = glossaryData[id];
				if (!term || !drawer) return;
				
				dTitle.innerText = term.title;
				dDef.innerText = term.def;
				dDetails.innerText = term.details;
				dLink.setAttribute('href', `${base}/methodology#${id}`);
				
				drawer.classList.add('open');
			};

			if (closeDrawer) {
				closeDrawer.addEventListener('click', () => drawer.classList.remove('open'));
			}

			// Smooth scroll for anchors
			document.body.addEventListener('click', (e) => {
				if (e.target.dataset.glossary) {
					e.preventDefault();
					window.openGlossary(e.target.dataset.glossary);
				}
			});
			// BibTeX Copy
			const bibBtn = document.getElementById('btn-bibtex');
			const bibContent = document.getElementById('bibtex-content');
			if (bibBtn && bibContent) {
				bibBtn.addEventListener('click', () => {
					navigator.clipboard.writeText(bibContent.innerText.trim()).then(() => {
						const original = bibBtn.innerText;
						bibBtn.innerText = 'Copied!';
						setTimeout(() => bibBtn.innerText = original, 2000);
					});
				});
			}
		</script>
	</body>
</html>

<style>
	.app-layout {
		display: flex;
		min-height: 100vh;
	}

	/* ===== MOBILE TOP BAR ===== */
	.mobile-topbar {
		display: none;
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		height: 56px;
		background: rgba(17, 24, 39, 0.95);
		backdrop-filter: blur(12px);
		border-bottom: 1px solid rgba(255,255,255,0.1);
		z-index: 200;
		align-items: center;
		padding: 0 1rem;
		gap: 1rem;
	}

	.mobile-title {
		font-family: 'Outfit', sans-serif;
		font-weight: 700;
		font-size: 1rem;
		color: #fff;
	}

	.menu-btn {
		background: none;
		border: none;
		cursor: pointer;
		display: flex;
		flex-direction: column;
		gap: 5px;
		padding: 4px;
	}

	.hamburger-line {
		display: block;
		width: 24px;
		height: 2px;
		background: #fff;
		border-radius: 2px;
		transition: transform 0.3s ease, opacity 0.3s ease;
	}

	.menu-btn.open .hamburger-line:nth-child(1) {
		transform: translateY(7px) rotate(45deg);
	}
	.menu-btn.open .hamburger-line:nth-child(2) {
		opacity: 0;
	}
	.menu-btn.open .hamburger-line:nth-child(3) {
		transform: translateY(-7px) rotate(-45deg);
	}

	.sidebar-overlay {
		display: none;
		position: fixed;
		inset: 0;
		background: rgba(0,0,0,0.6);
		z-index: 99;
		opacity: 0;
		transition: opacity 0.3s ease;
	}

	.sidebar-overlay.open {
		display: block;
		opacity: 1;
	}

	/* ===== SIDEBAR ===== */
	.sidebar {
		width: 280px;
		background: rgba(17, 24, 39, 0.8);
		backdrop-filter: blur(20px);
		border-right: 1px solid rgba(255, 255, 255, 0.1);
		padding: 2rem;
		display: flex;
		flex-direction: column;
		position: fixed;
		height: 100vh;
		z-index: 100;
		transition: transform 0.3s ease;
	}

	.sidebar-header {
		margin-bottom: 3rem;
	}

	.logo {
		width: 48px;
		height: 48px;
		background: var(--accent-primary);
		border-radius: 12px;
		display: flex;
		align-items: center;
		justify-content: center;
		font-family: 'Outfit', sans-serif;
		font-weight: 700;
		font-size: 1.25rem;
		margin-bottom: 1rem;
		color: #fff;
		box-shadow: 0 0 20px rgba(59, 130, 246, 0.5);
		animation: logo-breathe 4s ease-in-out infinite;
	}

	@keyframes logo-breathe {
		0%, 100% { box-shadow: 0 0 20px rgba(59, 130, 246, 0.5); }
		50% { box-shadow: 0 0 35px rgba(59, 130, 246, 0.8); }
	}

	.project-title {
		font-family: 'Outfit', sans-serif;
		font-size: 1.25rem;
		margin: 0;
		line-height: 1.2;
		color: #fff;
	}

	.main-nav {
		flex: 1;
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}

	.nav-item {
		display: flex;
		align-items: center;
		gap: 1rem;
		padding: 0.75rem 1rem;
		border-radius: 10px;
		color: var(--text-secondary);
		font-weight: 500;
		transition: all 0.3s ease;
	}

	.nav-item:hover, .nav-item.active {
		background: rgba(59, 130, 246, 0.1);
		color: var(--accent-primary);
		box-shadow: inset 3px 0 0 var(--accent-primary);
	}

	.nav-icon {
		font-size: 1.25rem;
	}

	.sidebar-footer {
		padding-top: 2rem;
		border-top: 1px solid rgba(255, 255, 255, 0.1);
		font-size: 0.875rem;
	}

	/* Theme Toggle */
	.theme-toggle {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.5rem 0.75rem;
		margin-bottom: 1rem;
		background: rgba(255,255,255,0.06);
		border: 1px solid rgba(255,255,255,0.1);
		border-radius: 8px;
		cursor: pointer;
		color: var(--text-secondary);
		font-size: 0.85rem;
		font-family: 'Inter', sans-serif;
		transition: all 0.3s ease;
		width: 100%;
	}
	.theme-toggle:hover {
		background: rgba(59, 130, 246, 0.1);
		color: var(--accent-primary);
		border-color: var(--accent-primary);
	}
	.theme-icon { font-size: 1rem; }
	:global(html.light) .theme-icon.sun { display: none; }
	:global(html:not(.light)) .theme-icon.moon { display: none; }

	.authors-list {
		margin-bottom: 0.75rem;
		display: flex;
		flex-direction: column;
		gap: 0.15rem;
	}

	.author {
		font-size: 0.775rem;
		color: #fff;
		font-weight: 500;
		opacity: 0.8;
		margin: 0;
	}

	.status {
		color: var(--text-muted);
	}

	.content {
		flex: 1;
		margin-left: 280px;
		padding: 0;
		background: radial-gradient(circle at top right, #1e3a8a 0%, #030712 40%);
		display: flex;
		flex-direction: column;
		min-height: 100vh;
		transition: background 0.4s ease;
	}

	/* ===== LIGHT THEME OVERRIDES ===== */
	:global(html.light) .sidebar {
		background: rgba(241, 245, 249, 0.95);
		border-right-color: rgba(0, 0, 0, 0.08);
	}
	:global(html.light) .project-title,
	:global(html.light) .author,
	:global(html.light) h1,
	:global(html.light) h2,
	:global(html.light) h3 {
		color: #0f172a !important;
	}
	:global(html.light) .subtitle {
		color: #475569 !important;
	}
	:global(html.light) .content {
		background: radial-gradient(circle at top right, #dbeafe 0%, #f8fafc 40%);
	}
	:global(html.light) .mobile-topbar {
		background: rgba(241, 245, 249, 0.95);
		border-bottom-color: rgba(0, 0, 0, 0.08);
	}
	:global(html.light) .mobile-title {
		color: #0f172a;
	}
	:global(html.light) .hamburger-line {
		background: #0f172a;
	}
	:global(html.light) .site-footer {
		background: rgba(241, 245, 249, 0.8);
		border-top-color: rgba(0, 0, 0, 0.08);
	}
	:global(html.light) .footer-col h4 {
		color: #1e293b;
	}
	:global(html.light) .footer-bottom p {
		color: #94a3b8;
	}

	/* ===== FOOTER ===== */
	.site-footer {
		margin-top: auto;
		border-top: 1px solid rgba(255, 255, 255, 0.08);
		background: rgba(3, 7, 18, 0.6);
		padding: 3rem 2rem 1.5rem;
	}

	.footer-inner {
		max-width: 1200px;
		margin: 0 auto;
		display: grid;
		grid-template-columns: 2fr 1.5fr 1fr;
		gap: 3rem;
	}

	.footer-col h4 {
		font-family: 'Outfit', sans-serif;
		font-size: 1rem;
		font-weight: 700;
		color: #e5e7eb;
		margin-bottom: 1rem;
	}

	.footer-col p {
		font-size: 0.875rem;
		color: #6b7280;
		line-height: 1.6;
	}

	.footer-col ul {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}

	.citation-box {
		background: rgba(255, 255, 255, 0.03);
		padding: 1rem;
		border-radius: 8px;
		border: 1px solid rgba(255, 255, 255, 0.05);
	}
	.citation-text {
		font-size: 0.75rem !important;
		line-height: 1.4 !important;
		margin-bottom: 0.75rem !important;
		color: var(--text-secondary) !important;
	}
	.btn-copy {
		background: transparent;
		border: 1px solid var(--accent-primary);
		color: var(--accent-primary);
		padding: 0.25rem 0.75rem;
		border-radius: 4px;
		font-size: 0.7rem;
		cursor: pointer;
		transition: all 0.2s;
	}
	.btn-copy:hover {
		background: var(--accent-primary);
		color: #fff;
	}
	.citation-actions {
		display: flex;
		gap: 0.5rem;
	}

	.footer-col ul li a {
		font-size: 0.85rem;
		color: #9ca3af;
		transition: color 0.2s;
	}

	.footer-col ul li a:hover {
		color: var(--accent-primary);
	}

	.footer-bottom {
		margin-top: 2rem;
		padding-top: 1.5rem;
		border-top: 1px solid rgba(255,255,255,0.06);
		text-align: center;
	}

	.footer-bottom p {
		font-size: 0.8rem;
		color: #4b5563;
	}

	/* ===== MOBILE ===== */
	@media (max-width: 768px) {
		.mobile-topbar {
			display: flex;
		}

		.sidebar {
			transform: translateX(-100%);
		}
		.sidebar.open {
			transform: translateX(0);
		}

		.content {
			margin-left: 0;
			padding-top: 56px;
		}

		.footer-inner {
			grid-template-columns: 1fr;
			gap: 2rem;
		}
	}
	.nav-divider {
		height: 1px;
		background: rgba(255,255,255,0.05);
		margin: 1rem 0;
	}

	/* Glossary Drawer */
	.glossary-drawer {
		position: fixed;
		top: 0;
		right: -400px;
		width: 400px;
		height: 100vh;
		background: #0f172a;
		border-left: 1px solid var(--accent-primary);
		box-shadow: -10px 0 30px rgba(0,0,0,0.5);
		z-index: 10000;
		transition: right 0.4s cubic-bezier(0.16, 1, 0.3, 1);
		padding: 2.5rem;
		display: flex;
		flex-direction: column;
	}
	.glossary-drawer.open { right: 0; }
	
	.drawer-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		margin-bottom: 2rem;
	}
	.drawer-header h3 { font-family: 'Outfit', sans-serif; color: #fff; margin: 0; }
	.close-btn { background: none; border: none; color: #fff; font-size: 2rem; cursor: pointer; }
	
	.drawer-desc { font-size: 1.1rem; line-height: 1.6; color: var(--text-secondary); margin-bottom: 2rem; }
	.drawer-meta h4 { font-size: 0.8rem; text-transform: uppercase; color: var(--accent-primary); margin-bottom: 0.75rem; }
	.drawer-meta p { font-size: 0.95rem; line-height: 1.6; color: var(--text-muted); }
	
	.btn-more {
		margin-top: auto;
		display: block;
		padding: 1rem;
		background: rgba(59, 130, 246, 0.1);
		color: var(--accent-primary);
		text-align: center;
		border-radius: 8px;
		font-weight: 600;
		transition: all 0.2s;
	}
	.btn-more:hover { background: var(--accent-primary); color: #fff; }

	@media (max-width: 500px) {
		.glossary-drawer { width: 100%; right: -100%; }
	}
</style>
