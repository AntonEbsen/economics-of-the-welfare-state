---
interface Props {
	title: string;
}

const { title } = Astro.props;
import '../styles/global.css';
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Economics of the Welfare State - Research Portal" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&family=Outfit:wght@500;700&display=swap" rel="stylesheet">
	</head>
	<body>
		<div class="app-layout">
			<aside class="sidebar">
				<div class="sidebar-header">
					<div class="logo">EWS</div>
					<h2 class="project-title">Economics of<br/>the Welfare State</h2>
				</div>
				<nav class="main-nav">
					<a href={`${base}/`} class="nav-item">
						<span class="nav-icon">🏠</span>
						Overview
					</a>
					<a href={`${base}/analysis`} class="nav-item">
						<span class="nav-icon">📈</span>
						Analysis
					</a>
					<a href={`${base}/map`} class="nav-item">
						<span class="nav-icon">🌍</span>
						Interactive Map
					</a>
					<a href={`${base}/appendix`} class="nav-item">
						<span class="nav-icon">📚</span>
						Appendix
					</a>
				</nav>
				<div class="sidebar-footer">
					<p class="author">By Anton Ebsen</p>
					<p class="status">Seminar Project 2026</p>
				</div>
			</aside>
			
			<main class="content">
				<slot />
			</main>
		</div>

		<script is:inline>
			// Active nav highlighting
			const navItems = document.querySelectorAll('.nav-item');
			const currentPath = window.location.pathname;
			navItems.forEach(item => {
				const href = item.getAttribute('href');
				// Exact match for home, prefix match for sub-pages
				if (href === currentPath || href + '/' === currentPath ||
				    (href !== '/' && currentPath.startsWith(href))) {
					item.classList.add('active');
				}
			});
		</script>
	</body>
</html>

<style>
	.app-layout {
		display: flex;
		min-height: 100vh;
	}

	.sidebar {
		width: 280px;
		background: rgba(17, 24, 39, 0.8);
		backdrop-filter: blur(20px);
		border-right: 1px solid rgba(255, 255, 255, 0.1);
		padding: 2rem;
		display: flex;
		flex-direction: column;
		position: fixed;
		height: 100vh;
		z-index: 100;
	}

	.sidebar-header {
		margin-bottom: 3rem;
	}

	.logo {
		width: 48px;
		height: 48px;
		background: var(--accent-primary);
		border-radius: 12px;
		display: flex;
		align-items: center;
		justify-content: center;
		font-family: 'Outfit', sans-serif;
		font-weight: 700;
		font-size: 1.25rem;
		margin-bottom: 1rem;
		color: #fff;
		box-shadow: 0 0 20px rgba(59, 130, 246, 0.5);
		animation: logo-breathe 4s ease-in-out infinite;
	}

	@keyframes logo-breathe {
		0%, 100% { box-shadow: 0 0 20px rgba(59, 130, 246, 0.5); }
		50% { box-shadow: 0 0 35px rgba(59, 130, 246, 0.8); }
	}

	.project-title {
		font-family: 'Outfit', sans-serif;
		font-size: 1.25rem;
		margin: 0;
		line-height: 1.2;
		color: #fff;
	}

	.main-nav {
		flex: 1;
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}

	.nav-item {
		display: flex;
		align-items: center;
		gap: 1rem;
		padding: 0.75rem 1rem;
		border-radius: 10px;
		color: var(--text-secondary);
		font-weight: 500;
		transition: all 0.3s ease;
	}

	.nav-item:hover, .nav-item.active {
		background: rgba(59, 130, 246, 0.1);
		color: var(--accent-primary);
		box-shadow: inset 3px 0 0 var(--accent-primary);
	}

	.nav-icon {
		font-size: 1.25rem;
	}

	.sidebar-footer {
		padding-top: 2rem;
		border-top: 1px solid rgba(255, 255, 255, 0.1);
		font-size: 0.875rem;
	}

	.author {
		color: #fff;
		font-weight: 600;
		margin-bottom: 0.25rem;
	}

	.status {
		color: var(--text-muted);
	}

	.content {
		flex: 1;
		margin-left: 280px;
		padding: 0;
		background: radial-gradient(circle at top right, #1e3a8a 0%, #030712 40%);
	}

	@media (max-width: 768px) {
		.sidebar {
			display: none; /* Mobile menu can be added later */
		}
		.content {
			margin-left: 0;
		}
	}
</style>
